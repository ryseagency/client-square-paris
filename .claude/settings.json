{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/pre-edit-protect.sh && exec .claude/hooks/pre-edit-protect.sh || true'"
          },
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/pre-edit-liquid-guard.sh && exec .claude/hooks/pre-edit-liquid-guard.sh || true'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/pre-bash-push-validator.sh && exec .claude/hooks/pre-bash-push-validator.sh || true'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/post-edit-quality.sh && exec .claude/hooks/post-edit-quality.sh || true'"
          },
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/post-edit-schema-validate.sh && exec .claude/hooks/post-edit-schema-validate.sh || true'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/stop-verification.sh && exec .claude/hooks/stop-verification.sh || true'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/userpromptsubmit-skill-injector.sh && exec .claude/hooks/userpromptsubmit-skill-injector.sh || true'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -x .claude/hooks/session-start-validator.sh && exec .claude/hooks/session-start-validator.sh || true'"
          }
        ]
      }
    ]
  }
}
