{%- liquid
  assign section_id = 'about-square-' | append: section.id
  assign options = section.settings

  assign image = options.image
  assign image_alt = options.image_alt

  assign eyebrow = options.eyebrow
  assign heading = options.heading
  assign heading_tag = options.heading_tag | default: 'h2'
  assign paragraph_1 = options.paragraph_1
  assign paragraph_2 = options.paragraph_2

  assign button_label = options.button_label
  assign button_link = options.button_link

  assign eyebrow_color = options.eyebrow_color | default: '#000000'
  assign heading_color = options.heading_color | default: '#000000'
  assign text_color = options.text_color | default: '#000000'
  assign bg_color = options.bg_color | default: '#FFFFFF'
  assign button_color = options.button_color | default: '#000000'

  assign heading_min = options.heading_size_min | default: 24
  assign heading_vw = options.heading_size_vw | default: 3
  assign heading_max = options.heading_size_max | default: 42

  assign image_ratio = options.image_ratio | default: '4/5'
  assign image_position = options.image_position | default: 'left'
-%}

{%- capture section_css -%}
  /* pt-0 md:pt-2 pb-14 md:pb-20 px-4 md:px-6 xl:px-8 */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding: 0 16px 28px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} { padding: 8px 24px 80px; }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} { padding-left: 32px; padding-right: 32px; }
  }

  #{{ section_id }} .abt__inner {
    max-width: 1760px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .abt__inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: stretch;
    }
  }

  /* Image : ratio 4/5, full width, reveal */
  #{{ section_id }} .abt__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ image_ratio }};
    background-color: #F5F3EE;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1.2s cubic-bezier(0.25,0.1,0,1), transform 1.2s cubic-bezier(0.25,0.1,0,1);
    {% if image_position == 'right' %}order: 2;{% endif %}
  }
  @media (min-width: 768px) {
    {% if image_position == 'right' %}
    #{{ section_id }} .abt__media { order: 2; }
    #{{ section_id }} .abt__content { order: 1; }
    {% endif %}
    #{{ section_id }} .abt__media {
      aspect-ratio: auto;
      height: 100%;
      min-height: 100%;
    }
  }
  #{{ section_id }}.is-visible .abt__media { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .abt__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Contenu */
  #{{ section_id }} .abt__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Eyebrow : ST Nova Sans 400 11px tracking 0.2em sq-noir/50 mb-4 */
  #{{ section_id }} .abt__eyebrow {
    display: block;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-weight: 400;
    font-size: 11px;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    opacity: 0;
    transform: translateY(20px);
    margin-bottom: 16px;
    line-height: 1;
    transition: opacity 1s ease-out 0.1s, transform 1s ease-out 0.1s;
  }
  #{{ section_id }}.is-visible .abt__eyebrow { opacity: 0.5; transform: translateY(0); }
  #{{ section_id }} .abt__eyebrow * { margin: 0; color: inherit; font-family: inherit; }

  /* Titre : Poppins 600 clamp leading-tight (1.25) mb-6 */
  #{{ section_id }} .abt__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    line-height: 1.25;
    color: {{ heading_color }};
    font-size: clamp({{ heading_min }}px, {{ heading_vw }}vw, {{ heading_max }}px);
    margin: 0 0 24px 0;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 1.1s ease-out 0.25s, transform 1.1s ease-out 0.25s;
  }
  #{{ section_id }}.is-visible .abt__heading { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .abt__heading * { font-family: inherit; font-weight: inherit; color: inherit; margin: 0; }

  /* Paragraphes : Poppins 300 15px sq-noir/70, pleine largeur de la colonne */
  #{{ section_id }} .abt__paragraph {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.6;
    color: {{ text_color }};
    max-width: 510px;
    margin: 0 0 16px 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }
  #{{ section_id }} .abt__paragraph--1 { transition-delay: 0.45s; }
  #{{ section_id }} .abt__paragraph--2 { transition-delay: 0.6s; margin-bottom: 32px; }
  #{{ section_id }}.is-visible .abt__paragraph { opacity: 0.7; transform: translateY(0); }
  #{{ section_id }} .abt__paragraph * { margin: 0; color: inherit; font-family: inherit; }

  /* CTA : Poppins 300 11px tracking 0.2em uppercase border-bottom */
  #{{ section_id }} .abt__btn {
    align-self: center;
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 11px;
    text-transform: uppercase;
    color: {{ button_color }};
    text-decoration: none;
    padding: 12px 32px;
    border: none;
    border-bottom: 1px solid rgba({{ button_color | color_extract: 'red' }}, {{ button_color | color_extract: 'green' }}, {{ button_color | color_extract: 'blue' }}, 0.2);
    background: transparent;
    cursor: pointer;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out 0.75s, transform 1s ease-out 0.75s, border-color 0.3s ease;
    white-space: nowrap;
  }
  #{{ section_id }}.is-visible .abt__btn { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .abt__btn:hover,
  #{{ section_id }} .abt__btn:focus-visible {
    border-bottom-color: {{ button_color }};
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .abt__media,
    #{{ section_id }} .abt__eyebrow,
    #{{ section_id }} .abt__heading,
    #{{ section_id }} .abt__paragraph,
    #{{ section_id }} .abt__btn {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    #{{ section_id }} .abt__eyebrow { opacity: 0.5 !important; }
    #{{ section_id }} .abt__paragraph { opacity: 0.7 !important; }
  }
{%- endcapture -%}

<style>{{ section_css }}</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap">

<section id="{{ section_id }}" class="abt" aria-labelledby="{{ section_id }}-heading">
  <div class="abt__inner">
    <div class="abt__media">
      {%- if image != blank -%}
        <img
          src="{{ image | image_url: width: 1200 }}"
          srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1600 }} 1600w"
          sizes="(min-width: 768px) 50vw, 100vw"
          alt="{{ image_alt | default: image.alt | default: heading | strip_html | escape }}"
          width="{{ image.width }}"
          height="{{ image.height }}"
          loading="lazy"
          decoding="async"
        >
      {%- endif -%}
    </div>

    <div class="abt__content">
      {%- if eyebrow != blank -%}
        <span class="abt__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}

      {%- if heading != blank -%}
        <{{ heading_tag }} id="{{ section_id }}-heading" class="abt__heading">{{ heading }}</{{ heading_tag }}>
      {%- endif -%}

      {%- if paragraph_1 != blank -%}
        <div class="abt__paragraph abt__paragraph--1">{{ paragraph_1 }}</div>
      {%- endif -%}

      {%- if paragraph_2 != blank -%}
        <div class="abt__paragraph abt__paragraph--2">{{ paragraph_2 }}</div>
      {%- endif -%}

      {%- if button_label != blank and button_link != blank -%}
        <a href="{{ button_link }}" class="abt__btn" title="{{ button_label | escape }}">
          {{ button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if ('IntersectionObserver' in window && !reduce) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) { section.classList.add('is-visible'); io.disconnect(); }
      });
    }, { threshold: 0.15 });
    io.observe(section);
  } else {
    section.classList.add('is-visible');
  }
})();
</script>

{%- if heading != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": {{ heading | strip_html | json }},
  {%- assign full_description = '' -%}
  {%- if paragraph_1 != blank -%}
    {%- assign full_description = paragraph_1 | strip_html -%}
  {%- endif -%}
  {%- if paragraph_2 != blank -%}
    {%- assign full_description = full_description | append: ' ' | append: paragraph_2 | strip_html -%}
  {%- endif -%}
  {%- if full_description != blank -%}
  "description": {{ full_description | strip | json }},
  {%- endif -%}
  {%- if image != blank -%}
  "image": {{ image | image_url: width: 1600 | prepend: 'https:' | json }},
  {%- endif -%}
  "url": {{ request.origin | append: request.path | json }}
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "À propos",
  "tag": "section",
  "class": "section-about-square",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Image", "info": "Ratio recommandé 4/5. Minimum 1200px de large." },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif (alt)", "info": "Important pour le SEO. Décrit précisément l'image. Si vide, utilise le titre." },
    {
      "type": "select", "id": "image_ratio", "label": "Ratio de l'image",
      "options": [
        { "value": "4/5", "label": "4:5 (portrait, par défaut)" },
        { "value": "3/4", "label": "3:4" },
        { "value": "1/1", "label": "1:1 (carré)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" }
      ],
      "default": "4/5"
    },
    {
      "type": "select", "id": "image_position", "label": "Position de l'image (desktop)",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },

    { "type": "header", "content": "Contenu" },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre", "default": "<p>La maison Square</p>" },
    { "type": "richtext", "id": "heading", "label": "Titre", "default": "<p>Un troisième chemin entre le mass-market et le luxe intimidant.</p>" },
    {
      "type": "select", "id": "heading_tag", "label": "Balise HTML du titre",
      "info": "H2 recommandé pour une section sur la page d'accueil.",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h1", "label": "H1" }
      ],
      "default": "h2"
    },
    { "type": "richtext", "id": "paragraph_1", "label": "Paragraphe 1", "default": "<p>Fondée par Beytulah Altuntas, SQUARE est née d'une conviction simple : le design français ne devrait pas être un privilège. Chaque meuble que nous créons conjugue la rigueur technique, la chaleur d'une fabrication artisanale et l'exigence d'un mobilier pensé pour traverser les années.</p>" },
    { "type": "richtext", "id": "paragraph_2", "label": "Paragraphe 2", "default": "<p>Notre promesse : réconcilier la beauté et la durabilité, le confort et le style, l'accessibilité et l'exigence. Parce que chaque ligne compte.</p>" },

    { "type": "header", "content": "Bouton" },
    { "type": "text", "id": "button_label", "label": "Libellé du bouton", "default": "Découvrir notre histoire" },
    { "type": "url", "id": "button_link", "label": "Lien du bouton" },

    { "type": "header", "content": "Typographie titre" },
    { "type": "range", "id": "heading_size_min", "label": "Taille min (mobile)", "min": 16, "max": 48, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "heading_size_vw", "label": "Taille fluide", "min": 2, "max": 8, "step": 1, "unit": "vw", "default": 3 },
    { "type": "range", "id": "heading_size_max", "label": "Taille max (desktop)", "min": 24, "max": 80, "step": 2, "unit": "px", "default": 42 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "bg_color", "label": "Fond de section", "default": "#FFFFFF" },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur sur-titre", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Couleur titre", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Couleur paragraphes", "default": "#000000" },
    { "type": "color", "id": "button_color", "label": "Couleur du bouton", "default": "#000000" }
  ],
  "presets": [
    {
      "name": "À propos",
      "category": "Contenu"
    }
  ]
}
{% endschema %}
