{%- liquid
  assign section_id = 'categories-grid-' | append: section.id
  assign options = section.settings

  assign eyebrow = options.eyebrow
  assign heading = options.heading
  assign subheading = options.subheading
  assign heading_tag = options.heading_tag | default: 'h2'
  assign text_align = options.text_align | default: 'center'

  assign eyebrow_color = options.eyebrow_color | default: '#000000'
  assign heading_color = options.heading_color | default: '#000000'
  assign text_color = options.text_color | default: '#000000'
  assign bg_color = options.bg_color | default: '#FFFFFF'
  assign card_label_color = options.card_label_color | default: '#EEECE5'
  assign card_overlay_color = options.card_overlay_color | default: '#000000'

  assign desktop_overlay_opacity = options.desktop_overlay_opacity | default: 20
  assign mobile_overlay_opacity = options.mobile_overlay_opacity | default: 20

  assign heading_min = options.heading_size_min | default: 24
  assign heading_vw = options.heading_size_vw | default: 3
  assign heading_max = options.heading_size_max | default: 42

  assign columns_desktop = options.columns_desktop | default: 4
  assign card_ratio = options.card_ratio | default: '3/4'
  assign mobile_layout = options.mobile_layout | default: 'stack'
-%}

{%- capture section_css -%}
  #{{ section_id }} {
    --cg-overlay-color: {{ card_overlay_color }};
    --cg-overlay-opacity: {{ mobile_overlay_opacity | times: 0.01 }};
    background-color: {{ bg_color }};
    padding: 56px 16px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} {
      --cg-overlay-opacity: {{ desktop_overlay_opacity | times: 0.01 }};
      padding: 40px 24px 80px;
    }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} { padding-left: 32px; padding-right: 32px; }
  }

  #{{ section_id }} .cg__inner { max-width: 1760px; margin: 0 auto; }

  #{{ section_id }} .cg__header {
    text-align: left;
    margin-bottom: 48px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .cg__header { text-align: {{ text_align }}; }
  }

  #{{ section_id }} .cg__eyebrow {
    display: block;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    opacity: 0;
    transform: translateY(20px);
    margin-bottom: 16px;
    line-height: 1;
    transition: opacity 1s ease-out 0.1s, transform 1s ease-out 0.1s;
  }
  #{{ section_id }}.is-visible .cg__eyebrow { opacity: 0.5; transform: translateY(0); }
  #{{ section_id }} .cg__eyebrow * { margin: 0; color: inherit; font-family: inherit; }

  #{{ section_id }} .cg__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    line-height: 1;
    color: {{ heading_color }};
    font-size: clamp({{ heading_min }}px, {{ heading_vw }}vw, {{ heading_max }}px);
    margin: 0;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 1.1s ease-out 0.25s, transform 1.1s ease-out 0.25s;
  }
  #{{ section_id }}.is-visible .cg__heading { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .cg__heading * { font-family: inherit; font-weight: inherit; color: inherit; margin: 0; }

  #{{ section_id }} .cg__sub {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.6;
    color: {{ text_color }};
    max-width: 600px;
    margin-top: 16px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out 0.5s, transform 1s ease-out 0.5s;
  }
  #{{ section_id }}.is-visible .cg__sub { opacity: 0.8; transform: translateY(0); }
  @media (min-width: 768px) {
    #{{ section_id }} .cg__header.cg--center .cg__sub { margin-left: auto; margin-right: auto; }
    #{{ section_id }} .cg__header.cg--right .cg__sub { margin-left: auto; }
  }
  #{{ section_id }} .cg__sub * { margin: 0; color: inherit; font-family: inherit; }

  /* Grille */
  #{{ section_id }} .cg__grid {
    {% if mobile_layout == 'carousel' %}
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    {% else %}
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    {% endif %}
  }
  {% if mobile_layout == 'carousel' %}
    #{{ section_id }} .cg__grid::-webkit-scrollbar { display: none; }
    #{{ section_id }} .cg__card {
      min-width: 75vw;
      scroll-snap-align: center;
      flex-shrink: 0;
    }
  {% endif %}
  @media (min-width: 768px) and (max-width: 1023.98px) {
    #{{ section_id }} .cg__grid {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    #{{ section_id }} .cg__grid::-webkit-scrollbar { display: none; }
    #{{ section_id }} .cg__card {
      flex: 0 0 calc((100% - 12px) / 2);
      min-width: calc((100% - 12px) / 2);
      scroll-snap-align: start;
    }
  }
  @media (min-width: 1024px) {
    #{{ section_id }} .cg__grid {
      display: grid;
      grid-template-columns: repeat({{ columns_desktop }}, 1fr);
      gap: 12px;
      overflow: visible;
    }
    #{{ section_id }} .cg__card { min-width: 0; }
  }

  /* Card */
  #{{ section_id }} .cg__card {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: {{ card_ratio }};
    text-decoration: none;
    isolation: isolate;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1.1s cubic-bezier(0.25,0.1,0,1), transform 1.1s cubic-bezier(0.25,0.1,0,1);
  }
  #{{ section_id }} .cg__card.is-visible { opacity: 1; transform: translateY(0); }

  /* Image : z-index 1 */
  #{{ section_id }} .cg__card-img {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }
  #{{ section_id }} .cg__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 800ms cubic-bezier(0.25,0.1,0,1);
  }
  #{{ section_id }} .cg__card:hover img,
  #{{ section_id }} .cg__card:focus-visible img { transform: scale(1.05); }

  /* Overlay : calque séparé, z-index 2, comme le hero */
  #{{ section_id }} .cg__card-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background-color: var(--cg-overlay-color);
    opacity: var(--cg-overlay-opacity);
    pointer-events: none;
    display: block;
    transition: opacity 800ms cubic-bezier(0.25,0.1,0,1);
  }
  #{{ section_id }} .cg__card:hover .cg__card-overlay,
  #{{ section_id }} .cg__card:focus-visible .cg__card-overlay { opacity: 0; }

  /* Label : z-index 3 */
  #{{ section_id }} .cg__card-label {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 3;
    padding: 20px;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-size: 26px;
    color: {{ card_label_color }};
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1;
  }

  #{{ section_id }} .cg__arrow { display: none !important; }

  /* Dots carousel mobile */
  #{{ section_id }} .cg__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  #{{ section_id }} .cg__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: {{ heading_color }};
    opacity: 0.2;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  #{{ section_id }} .cg__dot.is-active { opacity: 0.7; }
  @media (min-width: 1024px) {
    #{{ section_id }} .cg__dots { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .cg__eyebrow,
    #{{ section_id }} .cg__heading,
    #{{ section_id }} .cg__sub,
    #{{ section_id }} .cg__card,
    #{{ section_id }} .cg__card img,
    #{{ section_id }} .cg__card-overlay {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    #{{ section_id }} .cg__eyebrow { opacity: 0.5 !important; }
    #{{ section_id }} .cg__sub { opacity: 0.8 !important; }
    #{{ section_id }} .cg__card-overlay { opacity: var(--cg-overlay-opacity) !important; }
  }
{%- endcapture -%}

<style>{{ section_css }}</style>

<section id="{{ section_id }}" class="cg" aria-labelledby="{{ section_id }}-heading">
  <div class="cg__inner">
    <div class="cg__header cg--{{ text_align }}">
      {%- if eyebrow != blank -%}
        <span class="cg__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <{{ heading_tag }} id="{{ section_id }}-heading" class="cg__heading">{{ heading }}</{{ heading_tag }}>
      {%- endif -%}
      {%- if subheading != blank -%}
        <div class="cg__sub">{{ subheading }}</div>
      {%- endif -%}
    </div>

    <div class="cg__grid" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign b_image = block.settings.image
          assign b_label = block.settings.label
          assign b_link = block.settings.link
          assign b_alt = block.settings.image_alt | default: b_label
        -%}
        <a
          href="{{ b_link | default: '#' }}"
          class="cg__card"
          role="listitem"
          data-cg-card
          {{ block.shopify_attributes }}
          aria-label="{{ b_label | strip_html | escape }}"
          title="{{ b_label | strip_html | escape }}"
        >
          <div class="cg__card-img">
            {%- if b_image != blank -%}
              <img
                src="{{ b_image | image_url: width: 800 }}"
                srcset="{{ b_image | image_url: width: 400 }} 400w, {{ b_image | image_url: width: 600 }} 600w, {{ b_image | image_url: width: 800 }} 800w, {{ b_image | image_url: width: 1200 }} 1200w"
                sizes="(min-width: 1024px) {{ 100 | divided_by: columns_desktop }}vw, (min-width: 768px) 50vw, 100vw"
                alt="{{ b_alt | strip_html | escape }}"
                width="{{ b_image.width }}"
                height="{{ b_image.height }}"
                loading="lazy"
                decoding="async"
              >
            {%- endif -%}
          </div>

          <div class="cg__card-overlay" aria-hidden="true"></div>

          {%- if b_label != blank -%}
            <div class="cg__card-label">
              <span>{{ b_label }}</span>
            </div>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="cg__dots" aria-hidden="true">
        {%- for block in section.blocks -%}
          <button class="cg__dot{% if forloop.first %} is-active{% endif %}" data-cg-dot="{{ forloop.index0 }}"></button>
        {%- endfor -%}
      </div>
    {% endif %}
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var cards = section.querySelectorAll('[data-cg-card]');
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduce || !('IntersectionObserver' in window)) {
    section.classList.add('is-visible');
    cards.forEach(function(c){ c.classList.add('is-visible'); });
    return;
  }

  var headerIO = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { section.classList.add('is-visible'); headerIO.disconnect(); }
    });
  }, { threshold: 0.15 });
  headerIO.observe(section);

  /* Dots carousel */
  var grid = section.querySelector('.cg__grid');
  var dots = section.querySelectorAll('[data-cg-dot]');
  if (grid && dots.length > 0) {
    var updateDots = function() {
      var scrollLeft = grid.scrollLeft;
      var gridWidth = grid.scrollWidth - grid.clientWidth;
      if (gridWidth <= 0) return;
      var ratio = scrollLeft / gridWidth;
      var idx = Math.round(ratio * (dots.length - 1));
      dots.forEach(function(d, i) {
        d.classList.toggle('is-active', i === idx);
      });
    };
    grid.addEventListener('scroll', updateDots, { passive: true });
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var i = parseInt(this.getAttribute('data-cg-dot'), 10);
        var card = cards[i];
        if (card) {
          grid.scrollTo({ left: card.offsetLeft - (grid.clientWidth - card.clientWidth) / 2, behavior: 'smooth' });
        }
      });
    });
  }

  var cardsIO = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        var idx = Array.prototype.indexOf.call(cards, e.target);
        e.target.style.transitionDelay = (idx * 0.12) + 's';
        e.target.classList.add('is-visible');
        cardsIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
  cards.forEach(function(c){ cardsIO.observe(c); });
})();
</script>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  {% if heading != blank %}"name": {{ heading | strip_html | json }},{% endif %}
  {% if subheading != blank %}"description": {{ subheading | strip_html | json }},{% endif %}
  "numberOfItems": {{ section.blocks.size }},
  "itemListElement": [
    {%- for block in section.blocks -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "name": {{ block.settings.label | strip_html | json }}
        {%- if block.settings.link != blank -%},
        "url": {{ block.settings.link | prepend: request.origin | json }}
        {%- endif -%}
        {%- if block.settings.image != blank -%},
        "image": {{ block.settings.image | image_url: width: 1200 | prepend: 'https:' | json }}
        {%- endif -%}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Categories grid",
  "tag": "section",
  "class": "section-categories-grid",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Contenu" },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre", "default": "<p>Nos univers</p>" },
    { "type": "richtext", "id": "heading", "label": "Titre", "default": "<p>Chaque pièce, son caractère.</p>" },
    {
      "type": "select", "id": "heading_tag", "label": "Balise HTML du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h1", "label": "H1" }
      ],
      "default": "h2"
    },
    { "type": "richtext", "id": "subheading", "label": "Sous-titre", "default": "<p>Du salon à la chambre, retrouvez l'ensemble de notre catalogue organisé par pièce de vie.</p>" },
    {
      "type": "select", "id": "text_align", "label": "Alignement du texte (desktop)",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },

    { "type": "header", "content": "Typographie titre" },
    { "type": "range", "id": "heading_size_min", "label": "Taille min (mobile)", "min": 16, "max": 48, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "heading_size_vw", "label": "Taille fluide", "min": 2, "max": 8, "step": 1, "unit": "vw", "default": 3 },
    { "type": "range", "id": "heading_size_max", "label": "Taille max (desktop)", "min": 24, "max": 80, "step": 2, "unit": "px", "default": 42 },

    { "type": "header", "content": "Grille" },
    {
      "type": "select", "id": "mobile_layout", "label": "Affichage mobile",
      "options": [
        { "value": "stack", "label": "Empilé (1 colonne)" },
        { "value": "carousel", "label": "Carousel horizontal" }
      ],
      "default": "stack"
    },
    { "type": "range", "id": "columns_desktop", "label": "Colonnes (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    {
      "type": "select", "id": "card_ratio", "label": "Ratio des cartes",
      "options": [
        { "value": "3/4", "label": "3:4 (portrait)" },
        { "value": "4/5", "label": "4:5" },
        { "value": "1/1", "label": "1:1 (carré)" },
        { "value": "4/3", "label": "4:3 (paysage)" },
        { "value": "2/3", "label": "2:3" }
      ],
      "default": "3/4"
    },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "bg_color", "label": "Fond de section", "default": "#FFFFFF" },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur du sur-titre", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Couleur du titre", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Couleur du sous-titre", "default": "#000000" },
    { "type": "color", "id": "card_label_color", "label": "Couleur du label des cartes", "default": "#EEECE5" },

    { "type": "header", "content": "Overlay des cartes" },
    { "type": "color", "id": "card_overlay_color", "label": "Couleur de l'overlay", "default": "#000000" },
    { "type": "range", "id": "desktop_overlay_opacity", "label": "Opacité overlay (desktop)", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 20 },
    { "type": "range", "id": "mobile_overlay_opacity", "label": "Opacité overlay (mobile)", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 20 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Texte alternatif (alt)", "info": "Important pour le SEO. Si vide, utilise le label." },
        { "type": "text", "id": "label", "label": "Label", "default": "canapés" },
        { "type": "url", "id": "link", "label": "Lien" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Categories grid",
      "category": "Collection",
      "blocks": [
        { "type": "category", "settings": { "label": "canapés" } },
        { "type": "category", "settings": { "label": "chambres" } },
        { "type": "category", "settings": { "label": "meubles" } },
        { "type": "category", "settings": { "label": "tapis" } }
      ]
    }
  ]
}
{% endschema %}
