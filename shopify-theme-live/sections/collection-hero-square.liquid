{%- liquid
  assign section_id = 'chs-' | append: section.id
  assign noir = '#1A1A1A'
  assign hero_image = section.settings.image
  if hero_image == blank
    assign hero_image = collection.image
  endif
  assign hero_title = section.settings.title
  if hero_title == blank
    assign hero_title = collection.title
  endif
  assign image_alpha = 100 | minus: section.settings.overlay_opacity | times: 1.0 | divided_by: 100.0
-%}

{%- capture section_css -%}
#shopify-section-{{ section.id }} { margin: 0; }
#{{ section_id }} {
  position: relative;
  width: 100%;
  height: auto;
  min-height: 0;
  max-height: none;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: {{ noir }};
}
@media (min-width: 768px) {
  #{{ section_id }} {
    height: {{ section.settings.height_desktop }}vh;
    min-height: {{ section.settings.min_height_desktop }}px;
    max-height: {{ section.settings.max_height_desktop }}px;
  }
}
#{{ section_id }} .chs__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  z-index: 0;
}
#{{ section_id }} .chs__inner {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  text-align: center;
  padding: 0 16px 40px;
}
@media (min-width: 768px) {
  #{{ section_id }} .chs__inner {
    padding: 0 24px 56px;
  }
}
#{{ section_id }} .chs__kicker {
  font-family: 'Poppins', sans-serif;
  font-weight: 400;
  font-size: 10.5px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(245,243,238,0.8);
  margin: 0 0 16px;
  opacity: 0;
  transform: translateY(16px);
  animation: chs__rise 1s cubic-bezier(0.25,0.1,0,1) 0.2s forwards;
}
#{{ section_id }} .chs__title {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 300;
  color: #fff;
  line-height: 1.05;
  max-width: 720px;
  margin: 0;
  font-size: clamp(30px, 4.4vw, 58px);
  opacity: 0;
  transform: translateY(24px);
  animation: chs__rise 1.1s cubic-bezier(0.25,0.1,0,1) 0.35s forwards;
}
@keyframes chs__rise {
  to { opacity: 1; transform: translateY(0); }
}
{%- endcapture -%}

<style>{{ section_css }}</style>

<section id="{{ section_id }}" style="background:#000;">
  {%- if hero_image != blank -%}
    <img
      class="chs__img"
      style="opacity: {{ image_alpha }};"
      src="{{ hero_image | image_url: width: 2000 }}"
      srcset="{{ hero_image | image_url: width: 800 }} 800w, {{ hero_image | image_url: width: 1200 }} 1200w, {{ hero_image | image_url: width: 1800 }} 1800w, {{ hero_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt="{{ hero_title | escape }}"
      width="{{ hero_image.width }}"
      height="{{ hero_image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- endif -%}
  <div class="chs__inner">
    {%- if section.settings.kicker != blank -%}
      <span class="chs__kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if hero_title != blank -%}
      <h1 class="chs__title">{{ hero_title }}</h1>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection — Hero",
  "tag": "section",
  "class": "section-collection-hero-square",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (par défaut : image de la collection)"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Sur-titre",
      "default": "Collection — Hiver 2026"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre (par défaut : titre de la collection)",
      "default": "Les canapés signature."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacité de l'overlay (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 45
    },
    {
      "type": "header",
      "content": "Hauteur — mobile"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Hauteur (vh)",
      "min": 30,
      "max": 100,
      "step": 2,
      "default": 52
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Hauteur min (px)",
      "min": 200,
      "max": 600,
      "step": 10,
      "default": 380
    },
    {
      "type": "range",
      "id": "max_height_mobile",
      "label": "Hauteur max (px)",
      "min": 300,
      "max": 800,
      "step": 10,
      "default": 560
    },
    {
      "type": "header",
      "content": "Hauteur — desktop"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur (vh)",
      "min": 30,
      "max": 100,
      "step": 2,
      "default": 52
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Hauteur min (px)",
      "min": 200,
      "max": 800,
      "step": 10,
      "default": 380
    },
    {
      "type": "range",
      "id": "max_height_desktop",
      "label": "Hauteur max (px)",
      "min": 300,
      "max": 900,
      "step": 10,
      "default": 560
    }
  ],
  "presets": [
    {
      "name": "Collection — Hero"
    }
  ]
}
{% endschema %}
