{%- liquid
  assign muted = '#91928b'
  assign noir = section.settings.text_color | default: '#000000'
  assign section_id = 'cfv2-' | append: section.id
  assign h_size_mobile = section.settings.heading_size_mobile | default: 30
  assign h_size_desktop = section.settings.heading_size_desktop | default: 44
  assign h_weight = section.settings.heading_weight | default: 600
  assign form_id = 'ContactFormV2-' | append: section.id
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;500&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- capture section_css -%}
#shopify-section-{{ section.id }} {
  margin-top: {{ section.settings.margin_top_mobile }}px;
  margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
}
@media (min-width: 990px) {
  #shopify-section-{{ section.id }} {
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
  }
}

#{{ section_id }} {
  width: 100%;
  background: {{ section.settings.bg_color | default: '#ffffff' }};
  color: {{ noir }};
  font-family: 'Poppins', sans-serif;
  box-sizing: border-box;
}
#{{ section_id }} *,
#{{ section_id }} *::before,
#{{ section_id }} *::after { box-sizing: border-box; }

#{{ section_id }} .cfv2__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 56px;
  padding: 56px 20px;
}
@media (min-width: 990px) {
  #{{ section_id }} .cfv2__inner {
    grid-template-columns: minmax(0, 1.65fr) minmax(280px, 1fr);
    gap: 80px;
    padding: 80px 64px;
  }
}
@media (min-width: 1280px) {
  #{{ section_id }} .cfv2__inner {
    gap: 96px;
    padding: 96px 80px;
  }
}

#{{ section_id }} .cfv2__kicker {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 500;
  font-size: 13px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: {{ muted }};
  margin: 0 0 16px;
}
@media (min-width: 768px) {
  #{{ section_id }} .cfv2__kicker { font-size: 14px; margin-bottom: 18px; }
}

#{{ section_id }} .cfv2__heading {
  font-family: 'Poppins', sans-serif;
  font-weight: {{ h_weight }};
  font-size: {{ h_size_mobile }}px;
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: {{ noir }};
  margin: 0 0 32px;
}
@media (min-width: 768px) {
  #{{ section_id }} .cfv2__heading {
    font-size: {{ h_size_desktop }}px;
    margin-bottom: 40px;
  }
}

/* ---- FORM ---- */
#{{ section_id }} .cfv2__form { width: 100%; }
#{{ section_id }} .cfv2__row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
  margin-bottom: 28px;
}
@media (min-width: 640px) {
  #{{ section_id }} .cfv2__row--2 { grid-template-columns: 1fr 1fr; }
}

#{{ section_id }} .cfv2__field { position: relative; }
#{{ section_id }} .cfv2__label {
  display: block;
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 500;
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: lowercase;
  color: {{ muted }};
  margin-bottom: 8px;
}
#{{ section_id }} .cfv2__input,
#{{ section_id }} .cfv2__select,
#{{ section_id }} .cfv2__textarea {
  width: 100%;
  border: 0;
  border-bottom: 1px solid #d4d4d4;
  background: transparent;
  padding: 8px 0;
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  color: {{ noir }};
  outline: none;
  border-radius: 0;
  transition: border-color 0.2s ease;
}
#{{ section_id }} .cfv2__input:focus,
#{{ section_id }} .cfv2__select:focus,
#{{ section_id }} .cfv2__textarea:focus { border-bottom-color: {{ noir }}; }

#{{ section_id }} .cfv2__select {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
  background-repeat: no-repeat;
  background-position: right 0 center;
  background-size: 16px;
  padding-right: 28px;
}

#{{ section_id }} .cfv2__textarea {
  min-height: 130px;
  resize: vertical;
  line-height: 1.5;
}

/* File input */
#{{ section_id }} .cfv2__file-wrap {
  display: flex;
  align-items: center;
  gap: 14px;
  border-bottom: 1px solid #d4d4d4;
  padding: 8px 0;
}
#{{ section_id }} .cfv2__file-input { display: none; }
#{{ section_id }} .cfv2__file-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border: 1px solid #d4d4d4;
  background: transparent;
  cursor: pointer;
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: lowercase;
  color: {{ noir }};
  transition: border-color 0.2s ease, background 0.2s ease;
}
#{{ section_id }} .cfv2__file-btn:hover { border-color: {{ noir }}; }
#{{ section_id }} .cfv2__file-btn svg { width: 14px; height: 14px; }
#{{ section_id }} .cfv2__file-name {
  font-size: 13px;
  color: {{ muted }};
  font-family: 'Poppins', sans-serif;
}

#{{ section_id }} .cfv2__submit {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  padding: 16px 28px;
  border: 0;
  background: {{ noir }};
  color: #fff;
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 500;
  font-size: 13px;
  letter-spacing: 0.14em;
  text-transform: lowercase;
  cursor: pointer;
  transition: opacity 0.25s ease;
  margin-top: 12px;
}
#{{ section_id }} .cfv2__submit:hover { opacity: 0.85; }
#{{ section_id }} .cfv2__submit svg { width: 14px; height: 14px; transition: transform 0.25s ease; }
#{{ section_id }} .cfv2__submit:hover svg { transform: translateX(3px); }

#{{ section_id }} .cfv2__form-message {
  padding: 14px 16px;
  margin-bottom: 24px;
  font-size: 14px;
  font-family: 'Poppins', sans-serif;
}
#{{ section_id }} .cfv2__form-message--success { background: #f1f4ee; color: #3d3f30; }
#{{ section_id }} .cfv2__form-message--error { background: #fbecec; color: #8a2a2a; }

/* ---- HORAIRES (right column) ---- */
#{{ section_id }} .cfv2__hours {
  background: {{ section.settings.hours_bg | default: '#f7f6f2' }};
  padding: 36px 32px;
  align-self: start;
}
@media (min-width: 990px) {
  #{{ section_id }} .cfv2__hours { padding: 40px 36px; position: sticky; top: 24px; }
}
#{{ section_id }} .cfv2__hours-list {
  list-style: none;
  margin: 0 0 24px;
  padding: 0;
}
#{{ section_id }} .cfv2__hours-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 14px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  font-size: 14px;
}
#{{ section_id }} .cfv2__hours-item:last-child { border-bottom: 0; }
#{{ section_id }} .cfv2__hours-day { color: {{ noir }}; font-weight: 500; }
#{{ section_id }} .cfv2__hours-value { color: {{ muted }}; font-variant-numeric: tabular-nums; }
#{{ section_id }} .cfv2__hours-note {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: {{ muted }};
  margin: 0;
  padding-top: 4px;
}
#{{ section_id }} .cfv2__hours-note svg { width: 16px; height: 16px; flex-shrink: 0; }
{%- endcapture -%}
<style>{{ section_css }}</style>

<section id="{{ section_id }}" class="cfv2">
  <div class="cfv2__inner">
    <div class="cfv2__form-col">
      {%- if section.settings.kicker != blank -%}
        <p class="cfv2__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cfv2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- form 'contact', id: form_id, class: 'cfv2__form' -%}
        {%- if form.posted_successfully? -%}
          <p class="cfv2__form-message cfv2__form-message--success">
            {{ section.settings.success_message | default: 'Message envoyé. Nous revenons vers vous rapidement.' }}
          </p>
        {%- elsif form.errors -%}
          <div class="cfv2__form-message cfv2__form-message--error">
            {{ 'templates.contact.form.error_heading' | t }}
            <ul style="margin:6px 0 0; padding-left: 18px;">
              {%- for field in form.errors -%}
                <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="cfv2__row cfv2__row--2">
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-firstname-{{ section.id }}">prénom</label>
            <input class="cfv2__input" type="text" id="cfv2-firstname-{{ section.id }}" name="contact[Prénom]" autocomplete="given-name" value="{% if customer %}{{ customer.first_name }}{% endif %}" required>
          </div>
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-lastname-{{ section.id }}">nom</label>
            <input class="cfv2__input" type="text" id="cfv2-lastname-{{ section.id }}" name="contact[Nom]" autocomplete="family-name" value="{% if customer %}{{ customer.last_name }}{% endif %}" required>
          </div>
        </div>

        <div class="cfv2__row cfv2__row--2">
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-email-{{ section.id }}">email</label>
            <input class="cfv2__input" type="email" id="cfv2-email-{{ section.id }}" name="contact[email]" autocomplete="email" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
          </div>
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-phone-{{ section.id }}">téléphone</label>
            <input class="cfv2__input" type="tel" id="cfv2-phone-{{ section.id }}" name="contact[Téléphone]" autocomplete="tel" pattern="[0-9\s\-\+\.]{6,}" value="{% if customer %}{{ customer.phone }}{% endif %}">
          </div>
        </div>

        <div class="cfv2__row">
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-subject-{{ section.id }}">sujet</label>
            <select class="cfv2__select" id="cfv2-subject-{{ section.id }}" name="contact[Sujet]" required>
              <option value="" disabled selected>— Sélectionnez un sujet —</option>
              <option value="Question produit">Question produit</option>
              <option value="Disponibilité / délai">Disponibilité / délai</option>
              <option value="Devis sur mesure">Devis sur mesure</option>
              <option value="Suivi de commande">Suivi de commande</option>
              <option value="Livraison">Livraison</option>
              <option value="Rétractation">Rétractation</option>
              <option value="Retour produit">Retour produit</option>
              <option value="Garantie">Garantie</option>
              <option value="Service après-vente">Service après-vente</option>
              <option value="Informations">Informations générales</option>
              <option value="Partenariat / presse">Partenariat / presse</option>
              <option value="Autre">Autre</option>
            </select>
          </div>
        </div>

        <div class="cfv2__row">
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-message-{{ section.id }}">message</label>
            <textarea class="cfv2__textarea" id="cfv2-message-{{ section.id }}" name="contact[body]" rows="5" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>
        </div>

        <div class="cfv2__row">
          <div class="cfv2__field">
            <label class="cfv2__label" for="cfv2-file-{{ section.id }}">pièce jointe (optionnel)</label>
            <div class="cfv2__file-wrap">
              <input class="cfv2__file-input" type="file" id="cfv2-file-{{ section.id }}" name="contact[Pièce jointe]" accept="image/*,.pdf,.doc,.docx" data-cfv2-file>
              <label class="cfv2__file-btn" for="cfv2-file-{{ section.id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>choisir un fichier</span>
              </label>
              <span class="cfv2__file-name" data-cfv2-file-name>aucun fichier</span>
            </div>
          </div>
        </div>

        <button type="submit" class="cfv2__submit">
          <span>{{ section.settings.submit_label | default: 'envoyer le message' }}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      {%- endform -%}
    </div>

    <aside class="cfv2__hours-col">
      {%- if section.settings.hours_kicker != blank -%}
        <p class="cfv2__kicker">{{ section.settings.hours_kicker }}</p>
      {%- endif -%}
      {%- if section.settings.hours_heading != blank -%}
        <h2 class="cfv2__heading" style="margin-bottom: 20px;">{{ section.settings.hours_heading }}</h2>
      {%- endif -%}

      <div class="cfv2__hours">
        <ul class="cfv2__hours-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'hours_row' -%}
              <li class="cfv2__hours-item" {{ block.shopify_attributes }}>
                <span class="cfv2__hours-day">{{ block.settings.day }}</span>
                <span class="cfv2__hours-value">{{ block.settings.value }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
        {%- if section.settings.hours_note != blank -%}
          <p class="cfv2__hours-note">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{{ section.settings.hours_note }}</span>
          </p>
        {%- endif -%}
      </div>
    </aside>
  </div>
</section>

<script>
  (function(){
    var root = document.getElementById('{{ section_id }}');
    if (!root) return;
    var input = root.querySelector('[data-cfv2-file]');
    var name = root.querySelector('[data-cfv2-file-name]');
    if (input && name) {
      input.addEventListener('change', function(){
        if (input.files && input.files.length > 0) {
          name.textContent = input.files[0].name;
        } else {
          name.textContent = 'aucun fichier';
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Contact form V2",
  "tag": "section",
  "class": "section-contact-form-v2",
  "settings": [
    {
      "type": "header",
      "content": "Colonne formulaire"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Sur-titre",
      "default": "formulaire"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Écrivez-nous."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Libellé du bouton",
      "default": "envoyer le message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Message de confirmation",
      "default": "Message envoyé. Nous revenons vers vous rapidement."
    },
    {
      "type": "header",
      "content": "Colonne horaires"
    },
    {
      "type": "text",
      "id": "hours_kicker",
      "label": "Sur-titre",
      "default": "disponibilités"
    },
    {
      "type": "text",
      "id": "hours_heading",
      "label": "Titre",
      "default": "Horaires."
    },
    {
      "type": "text",
      "id": "hours_note",
      "label": "Note",
      "default": "Réponse garantie sous 2h ouvrées."
    },
    {
      "type": "color",
      "id": "hours_bg",
      "label": "Fond du bloc horaires",
      "default": "#f7f6f2"
    },
    {
      "type": "header",
      "content": "Typographie titre"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Taille du titre — mobile",
      "min": 18, "max": 60, "step": 1, "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Taille du titre — desktop",
      "min": 24, "max": 100, "step": 2, "unit": "px",
      "default": 44
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse du titre",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond de section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du titre",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Marges"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Marge haute — mobile",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Marge basse — mobile",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Marge haute — desktop",
      "min": 0, "max": 200, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Marge basse — desktop",
      "min": 0, "max": 200, "step": 4, "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "hours_row",
      "name": "Ligne horaire",
      "settings": [
        {
          "type": "text",
          "id": "day",
          "label": "Jour(s)",
          "default": "Lundi — Vendredi"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Horaires",
          "default": "9h — 19h"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form V2",
      "blocks": [
        { "type": "hours_row", "settings": { "day": "Lundi — Vendredi", "value": "9h — 19h" } },
        { "type": "hours_row", "settings": { "day": "Samedi", "value": "10h — 18h" } },
        { "type": "hours_row", "settings": { "day": "Dimanche", "value": "Fermé" } }
      ]
    }
  ]
}
{% endschema %}
