{%- liquid
  assign fond = '#3d3f30'
  assign blanc = '#F5F3EE'
  assign section_id = 'ctac-' | append: section.id
-%}

{%- capture section_css -%}
/* ── Margins ── */
#shopify-section-{{ section.id }} {
  margin-top: {{ section.settings.margin_top_mobile }}px;
  margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
}
@media (min-width: 990px) {
  #shopify-section-{{ section.id }} {
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
  }
}

/* ── Container ── */
#{{ section_id }} {
  width: 100%;
  background: {{ fond }};
  padding: 48px 20px;
}
@media (min-width: 768px) {
  #{{ section_id }} { padding: 56px 64px; }
}
@media (min-width: 1200px) {
  #{{ section_id }} { padding: 56px 80px; }
}

/* ── Layout ── */
#{{ section_id }} .ctac__layout {
  display: flex;
  flex-direction: column;
  gap: 40px;
}
@media (min-width: 990px) {
  #{{ section_id }} .ctac__layout {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 80px;
  }
}

/* ── Left column ── */
#{{ section_id }} .ctac__left {
  flex-shrink: 0;
}
@media (min-width: 990px) {
  #{{ section_id }} .ctac__left {
    max-width: 320px;
  }
}
#{{ section_id }} .ctac__subtitle {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-size: 11px;
  text-transform: uppercase;
  color: rgba(245,243,238,0.35);
  margin-bottom: 12px;
}
#{{ section_id }} .ctac__title {
  font-family: 'Poppins', sans-serif;
  font-size: 28px;
  font-weight: 600;
  color: {{ blanc }};
  margin: 0 0 16px;
  line-height: 1.2;
}
@media (min-width: 768px) {
  #{{ section_id }} .ctac__title {
    font-size: 32px;
  }
}
#{{ section_id }} .ctac__description {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  font-weight: 300;
  line-height: 1.6;
  color: rgba(245,243,238,0.4);
  margin: 0;
}

/* ── Right column — cards ── */
#{{ section_id }} .ctac__cards {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
@media (min-width: 600px) {
  #{{ section_id }} .ctac__cards {
    flex-direction: row;
    gap: 16px;
    align-items: center;
  }
}
#{{ section_id }} .ctac__cards-divider {
  display: none;
}
@media (min-width: 600px) {
  #{{ section_id }} .ctac__cards-divider {
    display: block;
    width: 1px;
    height: 36px;
    background: rgba(245,243,238,0.15);
    flex-shrink: 0;
  }
}
#{{ section_id }} .ctac__card {
  display: flex;
  align-items: center;
  gap: 16px;
  border: 1px solid rgba(245,243,238,0.15);
  border-radius: 0;
  padding: 20px 24px;
  text-decoration: none;
  transition: border-color 0.25s ease;
  min-width: 0;
}
@media (min-width: 600px) {
  #{{ section_id }} .ctac__card {
    min-width: 260px;
  }
}
#{{ section_id }} .ctac__card:hover {
  border-color: rgba(245,243,238,0.35);
}
#{{ section_id }} .ctac__card-icon {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(245,243,238,0.5);
}
#{{ section_id }} .ctac__card-icon svg {
  width: 20px;
  height: 20px;
}
#{{ section_id }} .ctac__card-body {
  flex: 1;
  min-width: 0;
}
#{{ section_id }} .ctac__card-label {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-size: 10px;
  text-transform: uppercase;
  color: rgba(245,243,238,0.4);
  margin-bottom: 4px;
}
#{{ section_id }} .ctac__card-value {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  font-weight: 400;
  color: {{ blanc }};
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
#{{ section_id }} .ctac__card-arrow {
  flex-shrink: 0;
  font-family: 'Poppins', sans-serif;
  font-size: 16px;
  color: rgba(245,243,238,0.3);
  transition: transform 0.25s ease;
}
#{{ section_id }} .ctac__card:hover .ctac__card-arrow {
  transform: translateX(3px);
}
{%- endcapture -%}

<style>{{ section_css }}</style>

{%- capture icon_phone -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
{%- endcapture -%}

{%- capture icon_email -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
{%- endcapture -%}

<div id="{{ section_id }}">
  <div class="ctac__layout">

    {%- comment -%} ══ Left column ══ {%- endcomment -%}
    <div class="ctac__left">
      {%- if section.settings.subtitle != blank -%}
        <div class="ctac__subtitle">{{ section.settings.subtitle }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="ctac__title">{{ section.settings.title | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="ctac__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ══ Contact cards ══ {%- endcomment -%}
    <div class="ctac__cards">
      {%- if section.settings.phone != blank -%}
        <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="ctac__card">
          <div class="ctac__card-icon">{{ icon_phone }}</div>
          <div class="ctac__card-body">
            <div class="ctac__card-label">{{ section.settings.phone_label }}</div>
            <div class="ctac__card-value">{{ section.settings.phone }}</div>
          </div>
          <span class="ctac__card-arrow">→</span>
        </a>
      {%- endif -%}

      <div class="ctac__cards-divider"></div>

      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="ctac__card">
          <div class="ctac__card-icon">{{ icon_email }}</div>
          <div class="ctac__card-body">
            <div class="ctac__card-label">{{ section.settings.email_label }}</div>
            <div class="ctac__card-value">{{ section.settings.email }}</div>
          </div>
          <span class="ctac__card-arrow">→</span>
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "CTA Contact",
  "class": "cta-contact-section",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "service client" },
    { "type": "textarea", "id": "title", "label": "Titre", "default": "Une question ?\nParlons-en." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Beytulah répond personnellement sous 2h,\ndu lundi au samedi." },
    { "type": "header", "content": "Téléphone" },
    { "type": "text", "id": "phone_label", "label": "Label téléphone", "default": "téléphone" },
    { "type": "text", "id": "phone", "label": "Numéro", "default": "+33 6 12 34 56 78" },
    { "type": "header", "content": "Email" },
    { "type": "text", "id": "email_label", "label": "Label email", "default": "email" },
    { "type": "text", "id": "email", "label": "Adresse email", "default": "contact@square-paris.fr" },
    { "type": "header", "content": "Marges" },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Marge supérieure — mobile",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Marge inférieure — mobile",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Marge supérieure — desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Marge inférieure — desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    }
  ],
  "presets": [
    {
      "name": "CTA Contact"
    }
  ]
}
{% endschema %}
