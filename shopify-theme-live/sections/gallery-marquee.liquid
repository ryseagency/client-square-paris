{%- liquid
  assign section_id = 'gallery-marquee-' | append: section.id
  assign options = section.settings

  assign eyebrow = options.eyebrow
  assign heading = options.heading
  assign subheading = options.subheading
  assign heading_tag = options.heading_tag | default: 'h2'
  assign text_align = options.text_align | default: 'center'

  assign bg_color = options.bg_color | default: '#FFFFFF'
  assign eyebrow_color = options.eyebrow_color | default: '#000000'
  assign heading_color = options.heading_color | default: '#000000'
  assign text_color = options.text_color | default: '#000000'

  assign heading_min = options.heading_size_min | default: 24
  assign heading_vw = options.heading_size_vw | default: 3
  assign heading_max = options.heading_size_max | default: 42

  assign image_width = options.image_width | default: 320
  assign image_ratio = options.image_ratio | default: '3/4'
  assign gap_px = options.gap_px | default: 12
  assign speed_seconds = options.speed_seconds | default: 40
  assign pause_on_hover = options.pause_on_hover

  assign padding_top_mobile = options.padding_top_mobile | default: 8
  assign padding_bottom_mobile = options.padding_bottom_mobile | default: 0
  assign padding_top_desktop = options.padding_top_desktop | default: 16
  assign padding_bottom_desktop = options.padding_bottom_desktop | default: 80
  assign margin_top_mobile = options.margin_top_mobile | default: 0
  assign margin_bottom_mobile = options.margin_bottom_mobile | default: 0
  assign margin_top_desktop = options.margin_top_desktop | default: 0
  assign margin_bottom_desktop = options.margin_bottom_desktop | default: 0
-%}

{%- capture section_css -%}
  /* Padding + margin paramétrables */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding: {{ padding_top_mobile }}px 16px {{ padding_bottom_mobile }}px;
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} {
      padding: {{ padding_top_desktop }}px 24px {{ padding_bottom_desktop }}px;
      margin: {{ margin_top_desktop }}px 0 {{ margin_bottom_desktop }}px;
    }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} { padding-left: 32px; padding-right: 32px; }
  }

  #{{ section_id }} .gm__inner { max-width: 1760px; margin: 0 auto; }

  /* Header */
  #{{ section_id }} .gm__header {
    text-align: left;
    margin-bottom: 40px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .gm__header { text-align: {{ text_align }}; }
  }

  /* Eyebrow : ST Nova Sans 400 11px tracking 0.2em noir/50 */
  #{{ section_id }} .gm__eyebrow {
    display: block;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-weight: 400;
    font-size: 11px;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    opacity: 0;
    transform: translateY(20px);
    margin-bottom: 16px;
    line-height: 1;
    transition: opacity 1s ease-out 0.1s, transform 1s ease-out 0.1s;
  }
  #{{ section_id }}.is-visible .gm__eyebrow { opacity: 0.5; transform: translateY(0); }
  #{{ section_id }} .gm__eyebrow * { margin: 0; color: inherit; font-family: inherit; }

  /* Titre : Poppins 600 clamp leading-tight */
  #{{ section_id }} .gm__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    line-height: 1.25;
    color: {{ heading_color }};
    font-size: clamp({{ heading_min }}px, {{ heading_vw }}vw, {{ heading_max }}px);
    margin: 0;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 1.1s ease-out 0.25s, transform 1.1s ease-out 0.25s;
  }
  #{{ section_id }}.is-visible .gm__heading { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .gm__heading * { font-family: inherit; font-weight: inherit; color: inherit; margin: 0; }

  /* Sous-titre : Poppins 300 15px noir/60 max-w-600 mt-4 */
  #{{ section_id }} .gm__sub {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.6;
    color: {{ text_color }};
    max-width: 600px;
    margin-top: 16px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out 0.45s, transform 1s ease-out 0.45s;
  }
  #{{ section_id }}.is-visible .gm__sub { opacity: 0.6; transform: translateY(0); }
  @media (min-width: 768px) {
    #{{ section_id }} .gm__header.gm--center .gm__sub { margin-left: auto; margin-right: auto; }
    #{{ section_id }} .gm__header.gm--right .gm__sub { margin-left: auto; }
  }
  #{{ section_id }} .gm__sub * { margin: 0; color: inherit; font-family: inherit; }

  /* Marquee wrapper : overflow hidden pour couper les bords */
  #{{ section_id }} .gm__viewport {
    overflow: hidden;
    width: 100%;
  }

  /* Track : animation translateX de 0 à -50% (on double les items) */
  #{{ section_id }} .gm__track {
    display: flex;
    gap: {{ gap_px }}px;
    width: max-content;
    animation: gm-scroll-{{ section.id }} {{ speed_seconds }}s linear infinite;
  }
  {% if pause_on_hover %}
    #{{ section_id }} .gm__track:hover { animation-play-state: paused; }
  {% endif %}

  @keyframes gm-scroll-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - {{ gap_px | divided_by: 2.0 }}px)); }
  }

  /* Item : largeur fixe */
  #{{ section_id }} .gm__item {
    flex-shrink: 0;
    width: {{ image_width }}px;
    aspect-ratio: {{ image_ratio }};
    overflow: hidden;
    background-color: #F5F3EE;
    display: block;
    position: relative;
  }
  #{{ section_id }} .gm__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 700ms cubic-bezier(0.25,0.1,0,1);
  }
  #{{ section_id }} .gm__item:hover img,
  #{{ section_id }} .gm__item:focus-visible img { transform: scale(1.03); }

  /* Empty */
  #{{ section_id }} .gm__empty {
    padding: 48px 24px;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: {{ text_color }};
    opacity: 0.5;
    border: 1px dashed rgba(0,0,0,0.15);
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .gm__eyebrow,
    #{{ section_id }} .gm__heading,
    #{{ section_id }} .gm__sub,
    #{{ section_id }} .gm__item img {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    #{{ section_id }} .gm__eyebrow { opacity: 0.5 !important; }
    #{{ section_id }} .gm__sub { opacity: 0.6 !important; }
    #{{ section_id }} .gm__track {
      animation: none !important;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
    }
  }
{%- endcapture -%}

<style>{{ section_css }}</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap">

<section id="{{ section_id }}" class="gm" aria-labelledby="{{ section_id }}-heading">
  <div class="gm__inner">
    <div class="gm__header gm--{{ text_align }}">
      {%- if eyebrow != blank -%}
        <span class="gm__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}

      {%- if heading != blank -%}
        <{{ heading_tag }} id="{{ section_id }}-heading" class="gm__heading">{{ heading }}</{{ heading_tag }}>
      {%- endif -%}

      {%- if subheading != blank -%}
        <div class="gm__sub">{{ subheading }}</div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.blocks.size == 0 -%}
    <div class="gm__inner">
      <div class="gm__empty">Ajoutez des images dans les réglages de la section.</div>
    </div>
  {%- else -%}
    <div class="gm__viewport" aria-label="{{ options.aria_label | default: 'Galerie' | escape }}">
      <div class="gm__track">
        {%- comment -%} On duplique les blocks pour créer l'effet infini seamless {%- endcomment -%}
        {%- for iteration in (1..2) -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign b_image = block.settings.image
              assign b_alt = block.settings.image_alt | default: block.settings.caption | default: 'Image'
              assign b_link = block.settings.link
            -%}

            {%- if b_image != blank -%}
              {%- if b_link != blank -%}
                <a href="{{ b_link }}" class="gm__item" {% if iteration == 2 %}aria-hidden="true" tabindex="-1"{% endif %}>
              {%- else -%}
                <div class="gm__item" {% if iteration == 2 %}aria-hidden="true"{% endif %}>
              {%- endif -%}

              <img
                src="{{ b_image | image_url: width: 600 }}"
                srcset="{{ b_image | image_url: width: 300 }} 300w, {{ b_image | image_url: width: 450 }} 450w, {{ b_image | image_url: width: 600 }} 600w, {{ b_image | image_url: width: 900 }} 900w"
                sizes="{{ image_width }}px"
                alt="{{ b_alt | strip_html | escape }}"
                width="{{ b_image.width }}"
                height="{{ b_image.height }}"
                loading="lazy"
                decoding="async"
              >

              {%- if b_link != blank -%}
                </a>
              {%- else -%}
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if ('IntersectionObserver' in window && !reduce) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) { section.classList.add('is-visible'); io.disconnect(); }
      });
    }, { threshold: 0.15 });
    io.observe(section);
  } else {
    section.classList.add('is-visible');
  }

  // Pause l'animation quand la section n'est pas visible (économie CPU)
  // + pause au survol (priorité au hover sur la visibilité)
  var track = section.querySelector('.gm__track');
  if (!track || reduce) return;

  var isVisible = true;
  var isHovered = false;
  var isUserPaused = false;
  var applyState = function() {
    track.style.animationPlayState = (isVisible && !isHovered && !isUserPaused) ? 'running' : 'paused';
  };

  if ('IntersectionObserver' in window) {
    var visIO = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        isVisible = e.isIntersecting;
        applyState();
      });
    }, { threshold: 0 });
    visIO.observe(section);
  }

  var viewport = section.querySelector('.gm__viewport');
  if (viewport) {
    viewport.addEventListener('mouseenter', function(){ isHovered = true; applyState(); });
    viewport.addEventListener('mouseleave', function(){ isHovered = false; applyState(); });
    viewport.addEventListener('focusin', function(){ isHovered = true; applyState(); });
    viewport.addEventListener('focusout', function(){ isHovered = false; applyState(); });
    viewport.addEventListener('touchstart', function(){ isHovered = true; applyState(); }, { passive: true });
    viewport.addEventListener('touchend', function(){ isHovered = false; applyState(); }, { passive: true });

    viewport.addEventListener('click', function(e) {
      var item = e.target.closest('.gm__item');
      if (!item || !viewport.contains(item)) return;

      // Au clic/tap: ne pas ouvrir l'image/lien, juste mettre en pause/reprendre.
      e.preventDefault();
      isUserPaused = !isUserPaused;
      applyState();
    });
  }

  applyState();
})();
</script>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  {% if heading != blank %}"name": {{ heading | strip_html | json }},{% endif %}
  {% if subheading != blank %}"description": {{ subheading | strip_html | json }},{% endif %}
  "numberOfItems": {{ section.blocks.size }},
  "associatedMedia": [
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}
      {
        "@type": "ImageObject",
        "contentUrl": {{ block.settings.image | image_url: width: 1200 | prepend: 'https:' | json }}
        {%- if block.settings.image_alt != blank -%},
        "description": {{ block.settings.image_alt | strip_html | json }}
        {%- endif -%}
        {%- if block.settings.caption != blank -%},
        "caption": {{ block.settings.caption | strip_html | json }}
        {%- endif -%}
      }{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Gallery marquee",
  "tag": "section",
  "class": "section-gallery-marquee",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Contenu" },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre", "default": "<p>Intérieurs</p>" },
    { "type": "richtext", "id": "heading", "label": "Titre", "default": "<p>Chez vous, à votre image.</p>" },
    {
      "type": "select", "id": "heading_tag", "label": "Balise HTML du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h1", "label": "H1" }
      ],
      "default": "h2"
    },
    { "type": "richtext", "id": "subheading", "label": "Sous-titre", "default": "<p>Découvrez comment nos clients ont intégré nos pièces dans leur quotidien.</p>" },
    {
      "type": "select", "id": "text_align", "label": "Alignement du texte (desktop)",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },
    { "type": "text", "id": "aria_label", "label": "Label ARIA de la galerie (SEO)", "default": "Galerie de témoignages" },

    { "type": "header", "content": "Carousel" },
    { "type": "range", "id": "image_width", "label": "Largeur des images", "min": 200, "max": 500, "step": 10, "unit": "px", "default": 320 },
    {
      "type": "select", "id": "image_ratio", "label": "Ratio des images",
      "options": [
        { "value": "3/4", "label": "3:4 (portrait, par défaut)" },
        { "value": "4/5", "label": "4:5" },
        { "value": "1/1", "label": "1:1 (carré)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "16/9", "label": "16:9" }
      ],
      "default": "3/4"
    },
    { "type": "range", "id": "gap_px", "label": "Espace entre images", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "speed_seconds", "label": "Durée d'un cycle complet", "min": 20, "max": 120, "step": 5, "unit": "s", "default": 40, "info": "Plus la valeur est grande, plus le défilement est lent." },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause au survol", "default": true },

    { "type": "header", "content": "Typographie titre" },
    { "type": "range", "id": "heading_size_min", "label": "Taille min (mobile)", "min": 16, "max": 48, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "heading_size_vw", "label": "Taille fluide", "min": 2, "max": 8, "step": 1, "unit": "vw", "default": 3 },
    { "type": "range", "id": "heading_size_max", "label": "Taille max (desktop)", "min": 24, "max": 80, "step": 2, "unit": "px", "default": 42 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "bg_color", "label": "Fond de section", "default": "#FFFFFF" },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur sur-titre", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Couleur titre", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Couleur texte secondaire", "default": "#000000" },

    { "type": "header", "content": "Padding (intérieur de la section)" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding haut (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bas (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top_desktop", "label": "Padding haut (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 16 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bas (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },

    { "type": "header", "content": "Margin (extérieur de la section)" },
    { "type": "range", "id": "margin_top_mobile", "label": "Margin haut (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom_mobile", "label": "Margin bas (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_top_desktop", "label": "Margin haut (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom_desktop", "label": "Margin bas (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Texte alternatif (alt)", "info": "Important pour le SEO. Décrit précisément l'image." },
        { "type": "text", "id": "caption", "label": "Légende (optionnel, utilisée pour le schema SEO)" },
        { "type": "url", "id": "link", "label": "Lien (optionnel)" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Gallery marquee",
      "category": "Image",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
