{%- comment -%}
  ============================================
  Section: Header v6
  - Snippet externe : snippets/header-drawer.liquid
  - Icônes SVG inline (pas de dépendance icon-*)
  - State machine anti-jitter Lenis
  ============================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign section_id = 'header-' | append: section.id

  assign is_home = false
  if template.name == 'index' or request.path == '/'
    assign is_home = true
  endif

  assign is_collection = false
  if template.name == 'collection'
    assign is_collection = true
  endif

  assign enable_transparent = false
  if s.enable_transparent_on_home and is_home
    assign enable_transparent = true
  endif
  if s.enable_transparent_on_collection and is_collection
    assign enable_transparent = true
  endif
-%}

<style>
  /* Swym: on garde le launcher dans le DOM et cliquable (programmatique),
     mais hors champ visuel. Pas de display:none ni pointer-events:none
     sinon le handler interne de Swym ne s'exécute pas. */
  #swym-plugin {
    position: fixed !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
    opacity: 0 !important;
    z-index: -1 !important;
  }
  #swym-anchor {
    transform: scale(0.01) !important;
    transform-origin: bottom right !important;
  }

  :root {
    --header-height-mobile: {{ s.height_mobile }}px;
    --header-height-desktop: {{ s.height_desktop }}px;
  }

  #{{ section_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: var(--header-height-mobile);
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    background-color: {{ s.bg_color }};
    color: {{ s.text_color }};
    border-bottom: 1px solid {{ s.border_color }};
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition:
      background-color 400ms ease,
      color 400ms ease,
      border-color 400ms ease,
      transform 350ms ease-out,
      backdrop-filter 400ms ease;
  }

  @media (min-width: 990px) {
    #{{ section_id }} { height: var(--header-height-desktop); }
  }

  #{{ section_id }}.is-transparent {
    background-color: transparent;
    color: {{ s.text_color_transparent }};
    border-bottom-color: transparent;
    -webkit-backdrop-filter: blur(0);
    backdrop-filter: blur(0);
  }

  #{{ section_id }}.is-sticky { position: fixed; top: 0; }
  #{{ section_id }}.is-hidden { transform: translateY(-100%); }

  #{{ section_id }} .header__inner {
    width: 100%;
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    gap: 16px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .header__inner { padding: 0 24px; }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} .header__inner { padding: 0 32px; }
  }

  #{{ section_id }} .header__nav {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 28px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    #{{ section_id }} .header__nav { display: flex; }
  }
  #{{ section_id }} .header__nav-link {
    font-family: var(--font-body-family);
    font-weight: 300;
    font-size: 11px;
    text-transform: uppercase;
    color: inherit;
    text-decoration: none;
    transition: opacity 300ms ease;
    white-space: nowrap;
    line-height: 1;
  }
  #{{ section_id }} .header__nav-link:hover,
  #{{ section_id }} .header__nav-link:focus-visible { opacity: 0.6; outline: none; }

  #{{ section_id }} .header__burger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 8px;
    margin-left: -8px;
    color: inherit;
    cursor: pointer;
    transition: opacity 300ms ease;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }
  #{{ section_id }} .header__burger:hover,
  #{{ section_id }} .header__burger:focus-visible { opacity: 0.6; outline: none; }
  @media (min-width: 1024px) {
    #{{ section_id }} .header__burger { display: none !important; }
  }
  #{{ section_id }} .header__burger svg { width: 22px; height: 22px; }

  #{{ section_id }} .header__logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    text-decoration: none;
    color: inherit;
    margin: 0;
    padding: 0;
    z-index: 1;
  }
  #{{ section_id }} .header__logo img {
    display: block;
    height: {{ s.logo_height_mobile }}px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    grid-area: 1 / 1;
    transition: opacity 400ms ease;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .header__logo img { height: {{ s.logo_height_desktop }}px; }
  }
  #{{ section_id }} .header__logo-transparent { opacity: 0; }
  #{{ section_id }}.is-transparent .header__logo-default { opacity: 0; }
  #{{ section_id }}.is-transparent .header__logo-transparent { opacity: 1; }

  #{{ section_id }} .header__actions {
    display: flex;
    align-items: center;
    gap: 20px;
    color: inherit;
    flex-shrink: 0;
    margin-left: auto;
    position: relative;
    z-index: 2;
  }
  #{{ section_id }} .header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 4px;
    color: inherit;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 300ms ease;
    position: relative;
  }
  #{{ section_id }} .header__action:hover,
  #{{ section_id }} .header__action:focus-visible { opacity: 0.6; outline: none; }
  #{{ section_id }} .header__action svg { width: 20px; height: 20px; }
  #{{ section_id }} .header__action--hide-mobile { display: none; }
  @media (min-width: 768px) {
    #{{ section_id }} .header__action--hide-mobile { display: flex; }
  }
  #{{ section_id }} .header__cart-count {
    position: absolute;
    top: -4px;
    right: -6px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background-color: {{ s.cart_badge_bg }};
    color: {{ s.cart_badge_color }};
    font-family: var(--font-body-family);
    font-size: 9px;
    font-weight: 500;
    line-height: 16px;
    text-align: center;
    border-radius: 50%;
    pointer-events: none;
  }
  #{{ section_id }} .header__cart-count[data-count="0"] { display: none; }
  #{{ section_id }} .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  #{{ section_id }} a:focus-visible,
  #{{ section_id }} button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }}, #{{ section_id }} * { transition: none !important; }
  }
</style>

<header id="{{ section_id }}" class="header{% if enable_transparent %} is-transparent{% endif %}" role="banner" data-enable-transparent="{{ enable_transparent }}">
  <div class="header__inner">

    <button type="button" class="header__burger" aria-label="Ouvrir le menu" aria-controls="header-drawer" aria-expanded="false" data-drawer-open>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="7" x2="21" y2="7"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="17" x2="21" y2="17"/>
      </svg>
    </button>

    {%- if s.menu != blank -%}
      <nav role="navigation" aria-label="Navigation principale">
        <ul class="header__nav" role="list">
          {%- for link in s.menu.links -%}
            <li>
              <a href="{{ link.url }}" class="header__nav-link"{% if link.current %} aria-current="page"{% endif %}>
                {{ link.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name | escape }} — Accueil">
      {%- if s.logo_default != blank -%}
        <img class="header__logo-default"
          src="{{ s.logo_default | image_url: width: 800 }}"
          srcset="{{ s.logo_default | image_url: width: 200 }} 200w, {{ s.logo_default | image_url: width: 400 }} 400w, {{ s.logo_default | image_url: width: 600 }} 600w, {{ s.logo_default | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) {{ s.logo_height_mobile | times: 4 }}px, {{ s.logo_height_desktop | times: 4 }}px"
          alt="{{ shop.name | escape }}"
          width="{{ s.logo_default.width }}" height="{{ s.logo_default.height }}"
          loading="eager" fetchpriority="high" decoding="async">
      {%- else -%}
        <span style="font-family: var(--font-heading-family); font-size: 24px;">{{ shop.name | escape }}</span>
      {%- endif -%}
      {%- if s.logo_transparent != blank -%}
        <img class="header__logo-transparent"
          src="{{ s.logo_transparent | image_url: width: 800 }}"
          srcset="{{ s.logo_transparent | image_url: width: 200 }} 200w, {{ s.logo_transparent | image_url: width: 400 }} 400w, {{ s.logo_transparent | image_url: width: 600 }} 600w, {{ s.logo_transparent | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) {{ s.logo_height_mobile | times: 4 }}px, {{ s.logo_height_desktop | times: 4 }}px"
          alt="{{ shop.name | escape }}"
          width="{{ s.logo_transparent.width }}" height="{{ s.logo_transparent.height }}"
          loading="eager" fetchpriority="high" decoding="async">
      {%- endif -%}
    </a>

    <div class="header__actions">
      {%- if s.show_search -%}
        <a href="{{ routes.search_url }}" class="header__action header__action--hide-mobile" aria-label="Rechercher">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <line x1="21" y1="21" x2="16.5" y2="16.5"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if s.show_header_wishlist -%}
        <a href="/pages/wishlist" class="header__action header__action--hide-mobile" aria-label="Ma wishlist" data-swym-open>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 17.5s-7-4.5-7-9a3.5 3.5 0 0 1 6.5-1.8L10 8l.5-1.3A3.5 3.5 0 0 1 17 8.5c0 4.5-7 9-7 9z"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__action header__action--hide-mobile" aria-label="{%- if customer -%}Mon compte{%- else -%}Se connecter{%- endif -%}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
          </svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" id="cart-icon-bubble" class="header__action" aria-label="Panier ({{ cart.item_count }})">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="header__cart-count" data-count="{{ cart.item_count }}" aria-hidden="true">{{ cart.item_count }}</span>
        <span class="visually-hidden">{{ cart.item_count }} articles dans le panier</span>
      </a>
    </div>
  </div>
</header>

{% render 'header-drawer', section: section %}

{%- if s.menu != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": [{%- for link in s.menu.links -%}{{ link.title | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
  "url": [{%- for link in s.menu.links -%}{{ link.url | prepend: shop.url | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]
}
</script>
{%- endif -%}

<script>
(function() {
  var header = document.getElementById('{{ section_id }}');
  if (!header) return;

  function tryOpenSwymDrawer() {
    var selectors = [
      '#notepad-anchor-title',
      '#swym-anchor #notepad-anchor-title',
      '#swym-anchor a',
      '#swym-anchor',
      '#swym-plugin a',
      '#swym-plugin'
    ];

    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (!el) continue;

      el.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));
      el.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }));
      if (typeof el.click === 'function') {
        el.click();
      } else {
        el.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
      }
      return true;
    }

    return false;
  }

  /* Pré-enregistre l'ouverture via la queue officielle SwymCallbacks pour les chargements tardifs */
  window.SwymCallbacks = window.SwymCallbacks || [];

  /* Délégation : capte tous les liens [data-swym-open] (header desktop ET drawer mobile) */
  document.addEventListener('click', function(event) {
    var trigger = event.target.closest && event.target.closest('[data-swym-open]');
    if (!trigger) return;

    event.preventDefault();

    if (tryOpenSwymDrawer()) return;

    /* Swym peut se charger après le header: on retente brièvement avant fallback */
    var attempts = 0;
    var maxAttempts = 12;
    var timer = window.setInterval(function() {
      attempts += 1;
      if (tryOpenSwymDrawer()) {
        window.clearInterval(timer);
        return;
      }
      if (attempts >= maxAttempts) {
        window.clearInterval(timer);
        window.location.href = '/pages/wishlist';
      }
    }, 250);
  });

  var enableTransparent = header.dataset.enableTransparent === 'true';
  var state = 'top';
  var lastScrollY = window.scrollY;
  var accumulatedUp = 0, accumulatedDown = 0, ticking = false;
  var DIRECTION_THRESHOLD = 10, TOP_THRESHOLD = 50, TRANSPARENT_THRESHOLD = 5;

  function setState(newState) {
    if (state === newState) return;
    state = newState;
    header.classList.remove('is-sticky', 'is-hidden');
    if (newState === 'hidden') header.classList.add('is-sticky', 'is-hidden');
    else if (newState === 'visible') header.classList.add('is-sticky');
  }

  function update() {
    var scrollY = window.scrollY;
    var delta = scrollY - lastScrollY;
    if (enableTransparent) {
      if (scrollY <= TRANSPARENT_THRESHOLD) header.classList.add('is-transparent');
      else header.classList.remove('is-transparent');
    }
    if (scrollY <= TOP_THRESHOLD) {
      setState('top'); accumulatedUp = 0; accumulatedDown = 0;
      lastScrollY = scrollY; ticking = false; return;
    }
    if (delta > 0) {
      accumulatedDown += delta; accumulatedUp = 0;
      if (accumulatedDown > DIRECTION_THRESHOLD) setState('hidden');
    } else if (delta < 0) {
      accumulatedUp += -delta; accumulatedDown = 0;
      if (accumulatedUp > DIRECTION_THRESHOLD) setState('visible');
    }
    lastScrollY = scrollY; ticking = false;
  }

  window.addEventListener('scroll', function() {
    if (!ticking) { window.requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
  update();
})();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    { "type": "header", "content": "Logos" },
    { "type": "paragraph", "content": "Logo principal : toutes les pages. Logo transparent : au-dessus du Hero homepage." },
    { "type": "image_picker", "id": "logo_default", "label": "Logo principal (sombre)" },
    { "type": "image_picker", "id": "logo_transparent", "label": "Logo transparent (clair)" },
    { "type": "range", "id": "logo_height_desktop", "label": "Hauteur logo desktop", "min": 20, "max": 300, "step": 5, "unit": "px", "default": 220 },
    { "type": "range", "id": "logo_height_mobile", "label": "Hauteur logo mobile", "min": 20, "max": 200, "step": 5, "unit": "px", "default": 160 },

    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu", "label": "Menu principal", "default": "main-menu" },

    { "type": "header", "content": "Actions" },
    { "type": "checkbox", "id": "show_search", "label": "Afficher l'icône recherche", "default": true },
    { "type": "checkbox", "id": "show_header_wishlist", "label": "Afficher l'icône wishlist dans le header", "default": true },

    { "type": "header", "content": "Dimensions" },
    { "type": "range", "id": "height_desktop", "label": "Hauteur header desktop", "min": 60, "max": 160, "step": 2, "unit": "px", "default": 90 },
    { "type": "range", "id": "height_mobile", "label": "Hauteur header mobile", "min": 50, "max": 120, "step": 2, "unit": "px", "default": 70 },
    { "type": "range", "id": "max_width", "label": "Largeur maximale", "min": 1200, "max": 2000, "step": 20, "unit": "px", "default": 1760 },

    { "type": "header", "content": "Mode transparent (homepage)" },
    { "type": "checkbox", "id": "enable_transparent_on_home", "label": "Transparent sur Hero", "default": true },
    { "type": "checkbox", "id": "enable_transparent_on_collection", "label": "Transparent sur pages collection", "default": true },
    { "type": "color", "id": "text_color_transparent", "label": "Couleur texte transparent", "default": "#EEECE5" },

    { "type": "header", "content": "Mode solide" },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Texte", "default": "#000000" },
    { "type": "color", "id": "border_color", "label": "Bordure bas", "default": "#0000000A" },

    { "type": "header", "content": "Badge panier" },
    { "type": "color", "id": "cart_badge_bg", "label": "Fond", "default": "#000000" },
    { "type": "color", "id": "cart_badge_color", "label": "Texte", "default": "#FFFFFF" },

    { "type": "header", "content": "Drawer mobile" },
    { "type": "image_picker", "id": "drawer_banner_image", "label": "Image bannière" },
    { "type": "text", "id": "drawer_banner_eyebrow", "label": "Sur-titre bannière", "default": "NOUVELLE COLLECTION" },
    { "type": "text", "id": "drawer_banner_title", "label": "Titre bannière", "default": "Essentiels 2026" },
    { "type": "url", "id": "drawer_banner_link", "label": "Lien bannière" },
    { "type": "text", "id": "drawer_subtitle_1", "label": "Sous-titre lien #1", "default": "Notre vision du luxe" },
    { "type": "text", "id": "drawer_subtitle_2", "label": "Sous-titre lien #2", "default": "Pièces iconiques" },
    { "type": "text", "id": "drawer_subtitle_3", "label": "Sous-titre lien #3", "default": "Depuis Paris" },
    { "type": "text", "id": "drawer_subtitle_4", "label": "Sous-titre lien #4", "default": "Nous rencontrer" },
    { "type": "link_list", "id": "drawer_quick_links", "label": "Menu accès rapide" },
    { "type": "text", "id": "drawer_address", "label": "Adresse", "default": "231 rue Saint-Honoré, Paris" },
    { "type": "text", "id": "drawer_email", "label": "Email", "default": "contact@squareparis.com" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
