{%- liquid
  assign section_id = 'hero-fullscreen-' | append: section.id
  assign options = section.settings

  assign bg_image = options.background_image
  assign bg_image_mobile = options.background_image_mobile
  assign eyebrow = options.eyebrow
  assign heading = options.heading
  assign subheading = options.subheading
  assign button_label = options.button_label
  assign button_link = options.button_link
  assign heading_tag = options.heading_tag | default: 'h1'
  assign show_scroll_line = options.show_scroll_line

  assign heading_color = options.heading_color | default: '#EEECE5'
  assign text_color = options.text_color | default: '#EEECE5'
  assign button_color = options.button_color | default: '#EEECE5'
  assign overlay_color = options.overlay_color | default: '#000000'

  assign desktop_overlay_opacity = options.desktop_overlay_opacity | default: 40
  assign mobile_overlay_opacity = options.mobile_overlay_opacity | default: 40

  assign heading_min = options.heading_size_min | default: 48
  assign heading_max = options.heading_size_max | default: 140
  assign heading_vw = options.heading_size_vw | default: 8
  assign content_align = options.content_alignment | default: 'bottom'

  assign seo_alt = bg_image.alt | default: heading | strip_html | escape
-%}

{%- capture section_css -%}
    #{{ section_id }} {
      --gsc-overlay-color: {{ overlay_color }};
      --gsc-overlay-opacity: {{ mobile_overlay_opacity | times: 0.01 }};
      --gsc-heading-color: {{ heading_color }};
      --gsc-text-color: {{ text_color }};
      --gsc-button-color: {{ button_color }};
      position: relative;
      height: 100vh;
      height: 100dvh;
      overflow: hidden;
      background-color: #000;
    }
    @media (min-width: 768px) {
      #{{ section_id }} {
        --gsc-overlay-opacity: {{ desktop_overlay_opacity | times: 0.01 }};
      }
    }

    #{{ section_id }} .hfs__media {
      position: absolute;
      inset: 0;
      z-index: 1;
      will-change: transform;
    }
    #{{ section_id }} .hfs__media img {
      width: 100%;
      height: 120%;
      object-fit: cover;
      display: block;
    }

    /* Overlay garanti visible : calque posé au-dessus de l'image, sous le contenu */
    #{{ section_id }} .hfs__overlay {
      position: absolute;
      inset: 0;
      background-color: var(--gsc-overlay-color);
      opacity: var(--gsc-overlay-opacity);
      pointer-events: none;
      z-index: 2;
      display: block;
    }

    #{{ section_id }} .hfs__content {
      position: relative;
      height: 100%;
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 16px;
      {% if content_align == 'center' %}justify-content: center;
      {% elsif content_align == 'top' %}justify-content: flex-start; padding-top: 120px;
      {% else %}justify-content: flex-end; padding-bottom: 96px;{% endif %}
    }
    @media (min-width: 768px) {
      #{{ section_id }} .hfs__content {
        {% if content_align == 'bottom' %}padding-bottom: 128px;{% endif %}
      }
    }
    @media (min-width: 768px) and (max-width: 1023.98px) {
      #{{ section_id }} .hfs__content {
        justify-content: center;
        padding-top: 16px;
        padding-bottom: 16px;
      }
    }

    #{{ section_id }} .hfs__eyebrow {
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 300;
      text-transform: uppercase;
      color: var(--gsc-text-color);
      margin-bottom: 16px;
    }

    #{{ section_id }} .hfs__heading {
      font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
      font-weight: 400;
      text-align: center;
      line-height: 0.95;
      color: var(--gsc-heading-color);
      font-size: clamp({{ heading_min }}px, {{ heading_vw }}vw, {{ heading_max }}px);
      margin: 0;
    }
    #{{ section_id }} .hfs__heading * { font-family: inherit; font-weight: inherit; color: inherit; margin: 0; }

    #{{ section_id }} .hfs__subheading {
      font-family: 'Poppins', sans-serif;
      font-weight: 300;
      text-align: center;
      font-size: 16px;
      line-height: 1.6;
      color: var(--gsc-text-color);
      margin-top: 24px;
      max-width: 480px;
    }
    #{{ section_id }} .hfs__subheading * { margin: 0; color: inherit; font-family: inherit; }

    #{{ section_id }} .hfs__cta-wrap {
      margin-top: 32px;
      display: flex;
      justify-content: center;
    }

    /* Bouton : pas de mouvement au hover, seule la bordure s'intensifie */
    #{{ section_id }} .hfs__btn {
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 300;
      text-transform: uppercase;
      padding: 12px 28px;
      color: var(--gsc-button-color);
      background: transparent;
      border: none;
      border-bottom: 1px solid color-mix(in srgb, var(--gsc-button-color) 40%, transparent);
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: border-bottom-color 0.5s ease;
    }
    #{{ section_id }} .hfs__btn:hover,
    #{{ section_id }} .hfs__btn:focus-visible {
      border-bottom-color: var(--gsc-button-color);
      transform: none;
    }

    #{{ section_id }} .hfs__scroll-line {
      display: block;
      width: 1px;
      height: 48px;
      margin: 32px auto 0;
      position: relative;
      overflow: hidden;
      opacity: 0;
      transition: opacity 0.8s ease;
    }
    #{{ section_id }} .hfs__scroll-line::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to bottom, var(--gsc-text-color) 0%, var(--gsc-text-color) 60%, transparent 100%);
      transform: translateY(-100%);
    }
    #{{ section_id }} .hfs__scroll-line.is-active {
      opacity: 1;
    }
    #{{ section_id }} .hfs__scroll-line.is-active::after {
      animation: hfs-slide-{{ section.id }} 2s ease-in-out infinite;
    }
    @keyframes hfs-slide-{{ section.id }} {
      0%   { transform: translateY(-100%); }
      100% { transform: translateY(100%); }
    }


    @media (prefers-reduced-motion: reduce) {
      #{{ section_id }} .hfs__media,
      #{{ section_id }} .hfs__eyebrow,
      #{{ section_id }} .hfs__heading,
      #{{ section_id }} .hfs__subheading,
      #{{ section_id }} .hfs__cta-wrap,
      #{{ section_id }} .hfs__btn {
        transition: none !important;
        animation: none !important;
        transform: none !important;
        opacity: 1 !important;
      }
      #{{ section_id }} .hfs__eyebrow { opacity: 0.8 !important; }
      #{{ section_id }} .hfs__subheading { opacity: 0.85 !important; }
      #{{ section_id }} .hfs__scroll-line { animation: none !important; opacity: 0.3 !important; }
    }
  {%- endcapture -%}

<style>{{ section_css }}</style>

<section
  id="{{ section_id }}"
  class="hfs"
  data-section-id="{{ section.id }}"
  data-sq-reveal-section
  aria-label="{{ heading | strip_html | escape }}"
  role="banner"
>
  {%- if bg_image != blank -%}
    <div class="hfs__media" data-hfs-media>
      <picture>
        {%- if bg_image_mobile != blank -%}
          <source
            media="(max-width: 767px)"
            srcset="{{ bg_image_mobile | image_url: width: 768 }} 768w, {{ bg_image_mobile | image_url: width: 1024 }} 1024w"
            sizes="100vw"
          >
        {%- endif -%}
        <img
          src="{{ bg_image | image_url: width: 1920 }}"
          srcset="{{ bg_image | image_url: width: 768 }} 768w, {{ bg_image | image_url: width: 1200 }} 1200w, {{ bg_image | image_url: width: 1920 }} 1920w, {{ bg_image | image_url: width: 2400 }} 2400w"
          sizes="100vw"
          alt="{{ seo_alt }}"
          width="{{ bg_image.width }}"
          height="{{ bg_image.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        >
      </picture>
    </div>
  {%- else -%}
    <div class="hfs__media" data-hfs-media></div>
  {%- endif -%}

  <div class="hfs__overlay" aria-hidden="true"></div>

  <div class="hfs__content">
    {%- if eyebrow != blank -%}
      <div class="hfs__eyebrow" data-reveal="fade-up" data-reveal-delay="0.2" data-reveal-opacity="0.8">{{ eyebrow }}</div>
    {%- endif -%}

    {%- if heading != blank -%}
      <{{ heading_tag }} class="hfs__heading" data-reveal="words" data-reveal-stagger="0.06">{{ heading }}</{{ heading_tag }}>
    {%- endif -%}

    {%- if subheading != blank -%}
      <div class="hfs__subheading" data-reveal="fade-up" data-reveal-delay="0.5" data-reveal-opacity="0.85">{{ subheading }}</div>
    {%- endif -%}

    {%- if button_label != blank and button_link != blank -%}
      <div class="hfs__cta-wrap" data-reveal="fade-up" data-reveal-delay="0.7">
        <a href="{{ button_link }}" class="hfs__btn" title="{{ button_label | escape }}">
          {{ button_label }}
        </a>
      </div>
    {%- endif -%}

    {%- if show_scroll_line -%}
      <div class="hfs__scroll-line" id="scroll-line-{{ section.id }}" aria-hidden="true"></div>
    {%- endif -%}
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* Scroll-line fade-in after 1.5s */
  var scrollLine = document.getElementById('scroll-line-{{ section.id }}');
  if (scrollLine) {
    setTimeout(function(){ scrollLine.classList.add('is-active'); }, 1500);
  }

  /* Parallax */
  var media = section.querySelector('[data-hfs-media]');
  if (media && !reduce) {
    var raf = null;
    var update = function(){
      var rect = section.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      var total = rect.height + vh;
      var progress = Math.min(Math.max((vh - rect.top) / total, 0), 1);
      var y = progress * -100;
      media.style.transform = 'translate3d(0,' + y.toFixed(2) + 'px,0)';
      raf = null;
    };
    var onScroll = function(){ if (raf === null) raf = requestAnimationFrame(update); };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
})();
</script>

{%- if heading != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPageElement",
  "name": {{ heading | strip_html | json }},
  {% if subheading != blank %}"description": {{ subheading | strip_html | json }},{% endif %}
  {% if bg_image != blank %}"image": {{ bg_image | image_url: width: 1920 | prepend: 'https:' | json }},{% endif %}
  {% if button_label != blank and button_link != blank %}"potentialAction": {
    "@type": "ViewAction",
    "name": {{ button_label | json }},
    "target": {{ button_link | json }}
  },{% endif %}
  "url": {{ request.origin | append: request.path | json }}
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Hero fullscreen",
  "tag": "section",
  "class": "section-hero-fullscreen place-under-transparent-header",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Contenu" },
    { "type": "image_picker", "id": "background_image", "label": "Image de fond (desktop)", "info": "1920×1080 px minimum. Renseigner l'attribut alt de l'image pour le SEO." },
    { "type": "image_picker", "id": "background_image_mobile", "label": "Image de fond (mobile)", "info": "Optionnel" },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre (eyebrow)", "default": "<p>Collection 2026</p>" },
    { "type": "richtext", "id": "heading", "label": "Titre principal", "default": "<p>every line matters.</p>" },
    {
      "type": "select", "id": "heading_tag", "label": "Balise HTML du titre",
      "info": "H1 pour l'accueil, H2 pour les autres pages",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h1"
    },
    { "type": "richtext", "id": "subheading", "label": "Sous-titre", "default": "<p>Le mobilier français pensé pour durer.</p>" },

    { "type": "header", "content": "Bouton CTA" },
    { "type": "text", "id": "button_label", "label": "Libellé du bouton", "default": "Découvrir la collection" },
    { "type": "url", "id": "button_link", "label": "Lien du bouton" },

    { "type": "header", "content": "Typographie titre" },
    { "type": "range", "id": "heading_size_min", "label": "Taille min (mobile)", "min": 28, "max": 80, "step": 2, "unit": "px", "default": 48 },
    { "type": "range", "id": "heading_size_vw", "label": "Taille fluide", "min": 4, "max": 14, "step": 1, "unit": "vw", "default": 8 },
    { "type": "range", "id": "heading_size_max", "label": "Taille max (desktop)", "min": 60, "max": 220, "step": 4, "unit": "px", "default": 140 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "heading_color", "label": "Couleur du titre", "default": "#EEECE5" },
    { "type": "color", "id": "text_color", "label": "Couleur du texte (sur-titre & sous-titre)", "default": "#EEECE5" },
    { "type": "color", "id": "button_color", "label": "Couleur du bouton", "default": "#EEECE5" },

    { "type": "header", "content": "Overlay" },
    { "type": "color", "id": "overlay_color", "label": "Couleur de l'overlay", "default": "#000000" },
    { "type": "range", "id": "desktop_overlay_opacity", "label": "Opacité overlay (desktop)", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 40 },
    { "type": "range", "id": "mobile_overlay_opacity", "label": "Opacité overlay (mobile)", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 40 },

    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "content_alignment", "label": "Position verticale du contenu",
      "options": [
        { "value": "top", "label": "Haut" },
        { "value": "center", "label": "Centre" },
        { "value": "bottom", "label": "Bas" }
      ],
      "default": "bottom"
    },
    { "type": "checkbox", "id": "show_scroll_line", "label": "Afficher la ligne de scroll animée", "default": true }
  ],
  "presets": [
    { "name": "Hero fullscreen", "category": "Hero" }
  ]
}
{% endschema %}
