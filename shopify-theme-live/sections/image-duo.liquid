{%- liquid
  assign section_id = 'image-duo-' | append: section.id
  assign options = section.settings

  assign label_color = options.label_color | default: '#EEECE5'
  assign overlay_color = options.overlay_color | default: '#000000'
  assign desktop_overlay_opacity = options.desktop_overlay_opacity | default: 30
  assign mobile_overlay_opacity = options.mobile_overlay_opacity | default: 30

  assign ratio = options.ratio | default: '16/13'
  assign gap_px = options.gap_px | default: 6
  assign side_padding_px = options.side_padding_px | default: 4
  assign padding_top_mobile = options.padding_top_mobile | default: 0
  assign padding_bottom_mobile = options.padding_bottom_mobile | default: 0
  assign padding_top_desktop = options.padding_top_desktop | default: 0
  assign padding_bottom_desktop = options.padding_bottom_desktop | default: 0

  assign label_min = options.label_size_min | default: 20
  assign label_vw = options.label_size_vw | default: 2
  assign label_max = options.label_size_max | default: 28

  assign ov_r = overlay_color | color_extract: 'red'
  assign ov_g = overlay_color | color_extract: 'green'
  assign ov_b = overlay_color | color_extract: 'blue'
-%}

{%- capture section_css -%}
  #{{ section_id }} {
    padding: {{ padding_top_mobile }}px {{ side_padding_px }}px {{ padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} {
      padding: {{ padding_top_desktop }}px {{ side_padding_px }}px {{ padding_bottom_desktop }}px;
    }
  }

  #{{ section_id }} .imd__grid {
    display: flex;
    flex-direction: column;
    gap: {{ gap_px }}px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .imd__grid { flex-direction: row; }
  }

  #{{ section_id }} .imd__card {
    position: relative;
    flex: 1;
    overflow: hidden;
    aspect-ratio: {{ ratio }};
    isolation: isolate;
    display: block;
    text-decoration: none;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 1.1s cubic-bezier(0.25,0.1,0,1), transform 1.1s cubic-bezier(0.25,0.1,0,1);
  }
  #{{ section_id }} .imd__card.is-visible { opacity: 1; transform: translateY(0); }

  #{{ section_id }} .imd__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 800ms cubic-bezier(0.25,0.1,0,1),
                filter 800ms cubic-bezier(0.25,0.1,0,1);
  }

  /* Overlay uniforme (comme hero-fullscreen) : calque posé sur l'image */
  #{{ section_id }} .imd__card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: rgba({{ ov_r }},{{ ov_g }},{{ ov_b }},{{ mobile_overlay_opacity | times: 0.01 }});
    pointer-events: none;
    display: block;
    transition: background-color 800ms cubic-bezier(0.25,0.1,0,1);
  }
  @media (min-width: 768px) {
    #{{ section_id }} .imd__card::after {
      background-color: rgba({{ ov_r }},{{ ov_g }},{{ ov_b }},{{ desktop_overlay_opacity | times: 0.01 }});
    }
  }

  /* Hover : scale-up l'image survolée */
  #{{ section_id }} .imd__card:hover img,
  #{{ section_id }} .imd__card:focus-visible img {
    transform: scale(1.02);
  }

  /* Hover : désature les autres cartes */
  #{{ section_id }} .imd__grid:hover .imd__card:not(:hover) img,
  #{{ section_id }} .imd__grid:focus-within .imd__card:not(:focus-within) img {
    filter: saturate(0.6);
  }

  /* Label : ST Nova Sans, bas-gauche, p-5 md:p-8 */
  #{{ section_id }} .imd__label {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 2;
    padding: 20px;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-weight: 400;
    color: {{ label_color }};
    font-size: clamp({{ label_min }}px, {{ label_vw }}vw, {{ label_max }}px);
    line-height: 1;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .imd__label { padding: 32px; }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .imd__card,
    #{{ section_id }} .imd__card img {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
      filter: none !important;
    }
  }
{%- endcapture -%}

<style>{{ section_css }}</style>

<section
  id="{{ section_id }}"
  class="imd"
  {%- if options.section_label != blank -%}
  aria-label="{{ options.section_label | escape }}"
  {%- endif -%}
>
  <div class="imd__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign b_image = block.settings.image
        assign b_label = block.settings.label
        assign b_link = block.settings.link
        assign b_alt = block.settings.image_alt | default: b_label
      -%}

      {%- if b_link != blank -%}
        <a
          href="{{ b_link }}"
          class="imd__card"
          data-imd-card
          {{ block.shopify_attributes }}
          aria-label="{{ b_label | strip_html | escape }}"
          title="{{ b_label | strip_html | escape }}"
        >
      {%- else -%}
        <div
          class="imd__card"
          data-imd-card
          {{ block.shopify_attributes }}
          role="img"
          aria-label="{{ b_alt | strip_html | escape }}"
        >
      {%- endif -%}

        {%- if b_image != blank -%}
          <img
            src="{{ b_image | image_url: width: 1200 }}"
            srcset="{{ b_image | image_url: width: 600 }} 600w, {{ b_image | image_url: width: 900 }} 900w, {{ b_image | image_url: width: 1200 }} 1200w, {{ b_image | image_url: width: 1600 }} 1600w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="{{ b_alt | strip_html | escape }}"
            width="{{ b_image.width }}"
            height="{{ b_image.height }}"
            loading="lazy"
            decoding="async"
          >
        {%- endif -%}

        {%- if b_label != blank -%}
          <span class="imd__label">{{ b_label }}</span>
        {%- endif -%}

      {%- if b_link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var cards = section.querySelectorAll('[data-imd-card]');
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduce || !('IntersectionObserver' in window)) {
    cards.forEach(function(c){ c.classList.add('is-visible'); });
    return;
  }

  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        var idx = Array.prototype.indexOf.call(cards, e.target);
        e.target.style.transitionDelay = (idx * 0.15) + 's';
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
  cards.forEach(function(c){ io.observe(c); });
})();
</script>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "numberOfItems": {{ section.blocks.size }},
  "associatedMedia": [
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}
      {
        "@type": "ImageObject",
        "contentUrl": {{ block.settings.image | image_url: width: 1600 | prepend: 'https:' | json }},
        "name": {{ block.settings.label | strip_html | json }}
        {%- if block.settings.image_alt != blank -%},
        "description": {{ block.settings.image_alt | strip_html | json }}
        {%- endif -%}
      }{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Image duo",
  "tag": "section",
  "class": "section-image-duo",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Général" },
    { "type": "text", "id": "section_label", "label": "Libellé ARIA de la section (SEO)", "info": "Ex: Univers de vie. Optionnel." },

    { "type": "header", "content": "Mise en page" },
    {
      "type": "select", "id": "ratio", "label": "Ratio des images",
      "options": [
        { "value": "16/13", "label": "16:13 (par défaut)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" },
        { "value": "1/1", "label": "1:1 (carré)" },
        { "value": "16/9", "label": "16:9" },
        { "value": "3/4", "label": "3:4 (portrait)" }
      ],
      "default": "16/13"
    },
    { "type": "range", "id": "gap_px", "label": "Espace entre images", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 6 },
    { "type": "range", "id": "side_padding_px", "label": "Padding latéral", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 4 },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding haut (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bas (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top_desktop", "label": "Padding haut (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bas (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Label" },
    { "type": "color", "id": "label_color", "label": "Couleur du label", "default": "#EEECE5" },
    { "type": "range", "id": "label_size_min", "label": "Taille min (mobile)", "min": 14, "max": 40, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "label_size_vw", "label": "Taille fluide", "min": 1, "max": 6, "step": 1, "unit": "vw", "default": 2 },
    { "type": "range", "id": "label_size_max", "label": "Taille max (desktop)", "min": 18, "max": 60, "step": 2, "unit": "px", "default": 28 },

    { "type": "header", "content": "Overlay" },
    { "type": "color", "id": "overlay_color", "label": "Couleur de l'overlay", "default": "#000000" },
    { "type": "range", "id": "desktop_overlay_opacity", "label": "Opacité overlay (desktop)", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 30 },
    { "type": "range", "id": "mobile_overlay_opacity", "label": "Opacité overlay (mobile)", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 30 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Texte alternatif (alt)", "info": "Décrit précisément l'image (SEO). Si vide, utilise le label." },
        { "type": "text", "id": "label", "label": "Label", "default": "l'art de recevoir." },
        { "type": "url", "id": "link", "label": "Lien (optionnel)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Image duo",
      "category": "Image",
      "blocks": [
        { "type": "image", "settings": { "label": "l'art de recevoir." } },
        { "type": "image", "settings": { "label": "l'intimité du repos." } }
      ]
    }
  ]
}
{% endschema %}
