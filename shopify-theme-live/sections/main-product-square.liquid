{%- liquid
  assign section_id = 'mps-' | append: section.id
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign noir = '#1A1A1A'
  assign creme = '#F5F3EE'
-%}

{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
{{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
{{ 'component-swatch.css' | asset_url | stylesheet_tag }}

{%- comment -%} Masquer le bouton Wishlist injecté automatiquement par Swym sous le bouton "Ajouter au panier" {%- endcomment -%}
<style>
  #swym-wishlist-cta,
  #swym-atw-pdp-button,
  #swym-atw-button-container,
  [id^="swym-atw-"],
  [id^="swym-atw-pdp"],
  [class*="swym-atw-pdp"],
  [class*="swym-atw-button"],
  .swym-add-to-wishlist-view-product,
  .swym-button.swym-add-to-wishlist-view-product,
  .product-form__buttons .swym-button,
  product-form .swym-button:not(.mps__wishlist),
  form[action*="/cart/add"] + .swym-button,
  form[action*="/cart/add"] ~ .swym-button {
    display: none !important;
    visibility: hidden !important;
    width: 0 !important;
    height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }
</style>

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- capture section_css -%}
#shopify-section-{{ section.id }} { margin-top: {{ section.settings.margin_top_mobile }}px; }
@media (min-width: 990px) {
  #shopify-section-{{ section.id }} { margin-top: {{ section.settings.margin_top_desktop }}px; }
}
#{{ section_id }} { background: #fff; }

/* ── Grid ── */
#{{ section_id }} .mps__grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
}
@media (min-width: 990px) {
  #{{ section_id }} .mps__grid {
    grid-template-columns: minmax(0, 55fr) minmax(0, 45fr);
  }
}

/* ── Gallery column ── */
#{{ section_id }} .mps__gallery-col {
  display: flex;
  flex-direction: column;
  background: {{ creme }};
  min-width: 0;
}
@media (min-width: 990px) {
  #{{ section_id }} .mps__gallery-col {
    position: sticky;
    top: 0;
    height: 90vh;
  }
}

#{{ section_id }} .mps__gallery {
  position: relative;
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
@media (max-width: 989px) {
  #{{ section_id }} .mps__gallery {
    aspect-ratio: 1 / 1;
  }
}

#{{ section_id }} .mps__gallery-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
}
@media (min-width: 990px) {
  #{{ section_id }} .mps__gallery-img {
    object-fit: cover;
  }
}
#{{ section_id }} .mps__gallery-img.is-active { opacity: 1; }

/* Badge nouveauté */
#{{ section_id }} .mps__badge {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 5;
  background: #eeece5;
  color: {{ noir }};
  padding: 6px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 10px;
  font-style: italic;
}
@media (max-width: 989px) {
  #{{ section_id }} .mps__badge {
    top: 80px;
  }
}

/* Counter 1/4 */
#{{ section_id }} .mps__counter {
  display: none;
}

/* Nav arrow */
#{{ section_id }} .mps__gallery-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 5;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  border: none;
  cursor: pointer;
  color: {{ noir }};
  transition: background 0.3s ease;
  -webkit-appearance: none;
}
#{{ section_id }} .mps__gallery-nav:hover { background: rgba(255,255,255,0.9); }
#{{ section_id }} .mps__gallery-nav--prev { left: 12px; }
#{{ section_id }} .mps__gallery-nav--next { right: 12px; }
#{{ section_id }} .mps__gallery-nav svg { width: 16px; height: 16px; }
@media (max-width: 989px) {
  #{{ section_id }} .mps__gallery-nav { display: none; }
}

/* Ambiance button */
#{{ section_id }} .mps__ambiance {
  position: absolute;
  bottom: 16px;
  right: 16px;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  border: none;
  padding: 8px 16px;
  cursor: pointer;
  font-family: 'Poppins', sans-serif;
  font-size: 11px;
  color: {{ noir }};
  transition: box-shadow 0.3s ease;
  -webkit-appearance: none;
}
#{{ section_id }} .mps__ambiance:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
#{{ section_id }} .mps__ambiance svg { width: 14px; height: 14px; }

/* Thumbnails */
#{{ section_id }} .mps__thumbs {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  overflow-y: hidden;
  flex-shrink: 0;
  flex-wrap: nowrap;
  max-width: 100%;
  scrollbar-width: none;
  -ms-overflow-style: none;
  scroll-snap-type: x proximity;
  -webkit-overflow-scrolling: touch;
  padding: 8px 12px;
  background: #fff;
}
@media (min-width: 990px) {
  #{{ section_id }} .mps__thumbs {
    gap: 2px;
    padding: 0;
    background: none;
  }
}
#{{ section_id }} .mps__thumbs::-webkit-scrollbar { display: none; }

#{{ section_id }} .mps__thumb {
  flex: 0 0 auto;
  width: 40px;
  height: 40px;
  border: 2px solid transparent;
  padding: 0;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  opacity: 0.5;
  transition: opacity 0.3s ease, border-color 0.3s ease;
  -webkit-appearance: none;
  background: none;
  scroll-snap-align: start;
}
@media (min-width: 990px) {
  #{{ section_id }} .mps__thumb {
    height: 140px;
    width: calc((100% - 8px) / 5);
    flex: 0 0 calc((100% - 8px) / 5);
    border: none;
  }
}
#{{ section_id }} .mps__thumb.is-active { opacity: 1; border-color: {{ noir }}; }
#{{ section_id }} .mps__thumb:hover { opacity: 0.85; }
@media (min-width: 990px) {
  #{{ section_id }} .mps__thumb.is-active { border-color: transparent; }
}
#{{ section_id }} .mps__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Info panel ── */
#{{ section_id }} .mps__info {
  padding: 24px 24px 40px;
  min-width: 0;
}
@media (min-width: 768px) {
  #{{ section_id }} .mps__info { padding: 32px 48px 48px; }
}
@media (min-width: 990px) {
  #{{ section_id }} .mps__info { padding: 36px 56px 56px; }
}

/* Breadcrumb */
#{{ section_id }} .mps__breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0;
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-size: 11px;
  color: rgba(26,26,26,0.35);
  margin-bottom: 20px;
}
#{{ section_id }} .mps__breadcrumb a {
  color: inherit;
  text-decoration: none;
  transition: color 0.3s ease;
}
#{{ section_id }} .mps__breadcrumb a:hover { color: {{ noir }}; }
#{{ section_id }} .mps__breadcrumb-sep {
  margin: 0 6px;
  font-size: 10px;
}
#{{ section_id }} .mps__breadcrumb-current {
  color: rgba(26,26,26,0.5);
}

/* Title row */
#{{ section_id }} .mps__title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 6px;
}
#{{ section_id }} .mps__title {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 600;
  font-size: clamp(28px, 4vw, 38px);
  text-transform: uppercase;
  color: {{ noir }};
  margin: 0;
  line-height: 1.1;
}

/* Rating */
#{{ section_id }} .mps__rating {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-shrink: 0;
  padding-top: 6px;
  text-decoration: none;
  cursor: pointer;
}
#{{ section_id }} .mps__star {
  width: 14px;
  height: 14px;
}
#{{ section_id }} .mps__star--filled { color: {{ noir }}; }
#{{ section_id }} .mps__star--empty { color: rgba(26,26,26,0.2); }
#{{ section_id }} .mps__rating-count {
  font-family: 'Poppins', sans-serif;
  font-size: 11px;
  color: rgba(26,26,26,0.35);
  margin-left: 4px;
  text-decoration: underline;
  text-underline-offset: 2px;
  white-space: nowrap;
}

/* Subtitle */
#{{ section_id }} .mps__subtitle {
  font-family: 'Poppins', sans-serif;
  font-weight: 400;
  font-size: 14px;
  color: rgba(26,26,26,0.55);
  margin: 0 0 8px;
  line-height: 1.5;
}

/* Divider */
#{{ section_id }} .mps__divider {
  border: none;
  height: 1px;
  background: rgba(26,26,26,0.06);
  margin: 12px 0;
}

/* Dimensions */
#{{ section_id }} .mps__dimensions {
  display: flex;
  align-items: stretch;
  gap: 0;
  margin-bottom: 20px;
  width: fit-content;
  max-width: 100%;
}
#{{ section_id }} .mps__dim-col {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 0 18px;
  border: none;
}
#{{ section_id }} .mps__dim-col:first-child {
  padding-left: 0;
}
#{{ section_id }} .mps__dim-col:last-child {
  padding-right: 0;
}
#{{ section_id }} .mps__dim-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}
#{{ section_id }} .mps__dim-icon {
  width: 14px;
  height: 14px;
  color: rgba(26,26,26,0.28);
  flex-shrink: 0;
}
#{{ section_id }} .mps__dim-label {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-size: 9px;
  font-weight: 400;
  text-transform: uppercase;
  color: rgba(26,26,26,0.35);
  margin: 0;
  line-height: 1;
  white-space: nowrap;
}
#{{ section_id }} .mps__dim-value {
  font-family: 'Poppins', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: {{ noir }};
  line-height: 1;
  white-space: nowrap;
}
#{{ section_id }} .mps__dim-unit {
  font-size: 12px;
  font-weight: 400;
  color: rgba(26,26,26,0.4);
  margin-left: 2px;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__dimensions {
    margin: 0 auto 18px;
  }
  #{{ section_id }} .mps__dim-col {
    padding: 0 12px;
  }
  #{{ section_id }} .mps__dim-meta {
    gap: 4px;
    margin-bottom: 4px;
  }
  #{{ section_id }} .mps__dim-icon {
    width: 12px;
    height: 12px;
  }
  #{{ section_id }} .mps__dim-label {
    font-size: 8px;
  }
  #{{ section_id }} .mps__dim-value {
    font-size: 16px;
  }
  #{{ section_id }} .mps__dim-unit {
    font-size: 11px;
  }
}

/* ── Reassurance badges ── */
#{{ section_id }} .mps__reassurance {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1px solid rgba(26,26,26,0.08);
  margin-bottom: 24px;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance {
    grid-template-columns: repeat(4, 1fr);
    margin-left: -1px;
    margin-right: -1px;
  }
}
#{{ section_id }} .mps__reassurance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px 8px;
  text-align: center;
  border-right: 1px solid rgba(26,26,26,0.08);
}
#{{ section_id }} .mps__reassurance-item:last-child { border-right: none; }
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance-item {
    padding: 10px 4px;
  }
}
#{{ section_id }} .mps__reassurance-icon {
  width: 28px;
  height: 28px;
  margin-bottom: 8px;
  object-fit: contain;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance-icon {
    width: 20px;
    height: 20px;
    margin-bottom: 4px;
  }
}
#{{ section_id }} .mps__reassurance-title {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 400;
  font-size: 10px;
  text-transform: lowercase;
  color: {{ noir }};
  margin-bottom: 2px;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance-title {
    font-size: 8px;
  }
}
#{{ section_id }} .mps__reassurance-sub {
  font-family: 'Poppins', sans-serif;
  font-weight: 400;
  font-size: 11px;
  color: rgba(26,26,26,0.55);
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance-sub {
    font-size: 8px;
  }
}

/* ── Reassurance V2 : liste éditoriale premium ── */
#{{ section_id }} .mps__reassurance2 {
  display: flex;
  flex-direction: column;
  margin-bottom: 24px;
  border-top: 1px solid rgba(26,26,26,0.08);
  border-bottom: 1px solid rgba(26,26,26,0.08);
}
#{{ section_id }} .mps__reassurance2-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 4px;
  border-bottom: 1px solid rgba(26,26,26,0.06);
}
#{{ section_id }} .mps__reassurance2-item:last-child { border-bottom: none; }
#{{ section_id }} .mps__reassurance2-ico {
  flex: 0 0 auto;
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: rgba(26,26,26,0.04);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: {{ noir }};
}
#{{ section_id }} .mps__reassurance2-ico img,
#{{ section_id }} .mps__reassurance2-ico svg {
  width: 22px;
  height: 22px;
  object-fit: contain;
}
#{{ section_id }} .mps__reassurance2-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}
#{{ section_id }} .mps__reassurance2-title {
  font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
  font-weight: 500;
  font-size: 14px;
  text-transform: lowercase;
  letter-spacing: 0.01em;
  color: {{ noir }};
  line-height: 1.2;
}
#{{ section_id }} .mps__reassurance2-sub {
  font-family: 'Poppins', sans-serif;
  font-weight: 400;
  font-size: 12px;
  color: rgba(26,26,26,0.6);
  line-height: 1.4;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance2-item {
    gap: 12px;
    padding: 12px 2px;
  }
  #{{ section_id }} .mps__reassurance2-ico {
    width: 36px;
    height: 36px;
    border-radius: 8px;
  }
  #{{ section_id }} .mps__reassurance2-ico img,
  #{{ section_id }} .mps__reassurance2-ico svg {
    width: 18px;
    height: 18px;
  }
  #{{ section_id }} .mps__reassurance2-title { font-size: 13px; }
  #{{ section_id }} .mps__reassurance2-sub { font-size: 11px; }
}
/* Variante compact / 2 colonnes */
#{{ section_id }} .mps__reassurance2.is-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 20px;
  border-top: none;
  border-bottom: none;
}
#{{ section_id }} .mps__reassurance2.is-grid .mps__reassurance2-item {
  border-bottom: 1px solid rgba(26,26,26,0.06);
  padding: 12px 0;
}
#{{ section_id }} .mps__reassurance2.is-grid .mps__reassurance2-item:nth-last-child(-n+2) {
  border-bottom: none;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance2.is-grid {
    grid-template-columns: 1fr;
  }
  #{{ section_id }} .mps__reassurance2.is-grid .mps__reassurance2-item:nth-last-child(-n+2) {
    border-bottom: 1px solid rgba(26,26,26,0.06);
  }
  #{{ section_id }} .mps__reassurance2.is-grid .mps__reassurance2-item:last-child {
    border-bottom: none;
  }
}

/* Variante "inline" : ligne horizontale minimaliste premium */
#{{ section_id }} .mps__reassurance2.is-inline {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  justify-content: space-between;
  gap: 0;
  padding: 18px 0;
  border-top: 1px solid rgba(26,26,26,0.1);
  border-bottom: 1px solid rgba(26,26,26,0.1);
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-item {
  flex: 1 1 0;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
  padding: 4px 10px;
  border-bottom: none;
  border-right: 1px solid rgba(26,26,26,0.08);
  text-align: center;
  min-width: 0;
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-item:last-child {
  border-right: none;
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-ico {
  width: 26px;
  height: 26px;
  border-radius: 0;
  background: transparent;
  color: {{ noir }};
  opacity: 0.85;
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-ico img,
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-ico svg {
  width: 24px;
  height: 24px;
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-text {
  align-items: center;
  gap: 3px;
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-title {
  font-family: 'Poppins', sans-serif;
  font-weight: 500;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: {{ noir }};
  line-height: 1.25;
}
#{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-sub {
  font-family: 'Poppins', sans-serif;
  font-weight: 400;
  font-size: 10px;
  color: rgba(26,26,26,0.5);
  line-height: 1.3;
  letter-spacing: 0.01em;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance2.is-inline {
    padding: 12px 0;
  }
  #{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-item {
    padding: 2px 6px;
    gap: 6px;
  }
  #{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-ico {
    width: 22px;
    height: 22px;
  }
  #{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-ico img,
  #{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-ico svg {
    width: 20px;
    height: 20px;
  }
  #{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-title {
    font-size: 9px;
    letter-spacing: 0.06em;
  }
  #{{ section_id }} .mps__reassurance2.is-inline .mps__reassurance2-sub {
    font-size: 9px;
  }
}

/* Mobile : slider horizontal (1 item visible à la fois, scroll snap) pour tous les layouts V2 */
#{{ section_id }} .mps__reassurance2-wrap {
  margin-bottom: 24px;
}
#{{ section_id }} .mps__reassurance2-dots {
  display: none;
}
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance2-wrap {
    margin-bottom: 20px;
  }
  #{{ section_id }} .mps__reassurance2-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
  }
  #{{ section_id }} .mps__reassurance2-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(26,26,26,0.2);
    transition: background 0.2s ease, width 0.2s ease;
    padding: 0;
    border: none;
    cursor: pointer;
    -webkit-appearance: none;
  }
  #{{ section_id }} .mps__reassurance2-dot.is-active {
    background: {{ noir }};
    width: 16px;
    border-radius: 3px;
  }
}
/* Mobile : slider horizontal (1 item visible à la fois, scroll snap) */
@media (max-width: 600px) {
  #{{ section_id }} .mps__reassurance2-wrap .mps__reassurance2 {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 0;
    padding: 14px 0;
    margin-left: -16px;
    margin-right: -16px;
    padding-left: 16px;
    padding-right: 16px;
    border-top: 1px solid rgba(26,26,26,0.1);
    border-bottom: 1px solid rgba(26,26,26,0.1);
    grid-template-columns: none;
