{%- liquid
  assign section_id = 'slider-split-' | append: section.id
  assign options = section.settings

  assign eyebrow = options.eyebrow
  assign heading_tag = options.heading_tag | default: 'h2'

  assign bg_color = options.bg_color | default: '#3D4030'
  assign eyebrow_color = options.eyebrow_color | default: '#EEECE5'
  assign heading_color = options.heading_color | default: '#EEECE5'
  assign text_color = options.text_color | default: '#EEECE5'
  assign dot_color = options.dot_color | default: '#EEECE5'

  assign heading_min = options.heading_size_min | default: 24
  assign heading_vw = options.heading_size_vw | default: 3
  assign heading_max = options.heading_size_max | default: 42

  assign autoplay = options.autoplay
  assign interval_ms = options.interval_seconds | default: 5 | times: 1000
  assign image_ratio = options.image_ratio | default: '4/3'
  assign image_position = options.image_position | default: 'right'

  assign dot_r = dot_color | color_extract: 'red'
  assign dot_g = dot_color | color_extract: 'green'
  assign dot_b = dot_color | color_extract: 'blue'
-%}

{%- capture section_css -%}
  /* py-6 md:py-8 px-4 md:px-6 xl:px-8 */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding: 40px 16px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} { padding: 32px 24px; }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} { padding-left: 32px; padding-right: 32px; }
  }

  #{{ section_id }} .sls__inner {
    max-width: 1760px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    #{{ section_id }} .sls__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 48px;
    }
  }

  /* Colonnes : width 100% pour prendre toute la largeur de leur cellule */
  #{{ section_id }} .sls__text,
  #{{ section_id }} .sls__media {
    width: 100%;
    min-width: 0;
  }

  /* Position image : right (default) ou left */
  {% if image_position == 'left' %}
    @media (min-width: 1024px) {
      #{{ section_id }} .sls__media { order: 1; }
      #{{ section_id }} .sls__text { order: 2; }
    }
  {% endif %}

  /* Colonne texte */
  #{{ section_id }} .sls__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Eyebrow : ST Nova Sans 400 11px tracking 0.2em crème/50 mb-4 */
  #{{ section_id }} .sls__eyebrow {
    display: block;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-weight: 400;
    font-size: 11px;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    opacity: 0;
    transform: translateY(20px);
    margin-bottom: 16px;
    line-height: 1;
    transition: opacity 1s ease-out 0.1s, transform 1s ease-out 0.1s;
  }
  #{{ section_id }}.is-visible .sls__eyebrow { opacity: 0.5; transform: translateY(0); }
  #{{ section_id }} .sls__eyebrow * { margin: 0; color: inherit; font-family: inherit; }

  /* Titre : Poppins 600 clamp leading-tight mb-4 — transitions slide */
  #{{ section_id }} .sls__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    line-height: 1.25;
    color: {{ heading_color }};
    font-size: clamp({{ heading_min }}px, {{ heading_vw }}vw, {{ heading_max }}px);
    margin: 0 0 16px 0;
    min-height: 1.25em;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #{{ section_id }} .sls__heading.is-switching {
    opacity: 0;
    transform: translateY(-6px);
  }

  /* Paragraphe : Poppins 300 15px mb-6 — largeur pour 2 lignes environ */
  #{{ section_id }} .sls__text-body {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.6;
    color: {{ text_color }};
    opacity: 0.75;
    max-width: 520px;
    margin: 0 0 24px 0;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #{{ section_id }} .sls__text-body * {
    margin: 0;
    color: inherit;
    font-family: inherit;
  }
  #{{ section_id }} .sls__text-body a {
    color: inherit;
    text-decoration: underline;
  }
  #{{ section_id }} .sls__text-body.is-switching {
    opacity: 0;
    transform: translateY(6px);
  }

  /* Dots : barres pilules avec progress */
  #{{ section_id }} .sls__dots {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  #{{ section_id }} .sls__dot {
    position: relative;
    width: 32px;
    height: 3px;
    border-radius: 999px;
    overflow: hidden;
    border: none;
    padding: 0;
    cursor: pointer;
    background-color: rgba({{ dot_r }},{{ dot_g }},{{ dot_b }},0.15);
    transition: background-color 0.3s ease;
  }
  #{{ section_id }} .sls__dot-fill {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background-color: rgba({{ dot_r }},{{ dot_g }},{{ dot_b }},0.8);
    transform: scaleX(0);
    transform-origin: left center;
  }
  #{{ section_id }} .sls__dot[data-state="done"] .sls__dot-fill {
    transform: scaleX(1);
    background-color: rgba({{ dot_r }},{{ dot_g }},{{ dot_b }},0.5);
  }
  {% if autoplay %}
    #{{ section_id }} .sls__dot[data-state="active"] .sls__dot-fill {
      animation: sls-progress-{{ section.id }} {{ interval_ms }}ms linear forwards;
    }
    @keyframes sls-progress-{{ section.id }} {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
  {% else %}
    #{{ section_id }} .sls__dot[data-state="active"] .sls__dot-fill {
      transform: scaleX(1);
    }
  {% endif %}

  /* Image : ratio 4/3 avec transition fade + scale */
  #{{ section_id }} .sls__media {
    overflow: hidden;
    background-color: rgba(0,0,0,0.1);
    aspect-ratio: {{ image_ratio }};
  }
  #{{ section_id }} .sls__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #{{ section_id }} .sls__media img.is-switching {
    opacity: 0;
    transform: scale(1.02);
  }

  /* Reveal initial */
  #{{ section_id }} .sls__heading,
  #{{ section_id }} .sls__text-body,
  #{{ section_id }} .sls__dots,
  #{{ section_id }} .sls__media {
    opacity: 0;
    transform: translateY(20px);
  }
  #{{ section_id }}.is-visible .sls__heading,
  #{{ section_id }}.is-visible .sls__text-body,
  #{{ section_id }}.is-visible .sls__dots,
  #{{ section_id }}.is-visible .sls__media {
    opacity: 1;
    transform: translateY(0);
  }
  #{{ section_id }}.is-visible .sls__text-body { opacity: 0.75; }
  #{{ section_id }}.is-visible .sls__heading { transition: opacity 1.1s ease-out 0.25s, transform 1.1s ease-out 0.25s; }
  #{{ section_id }}.is-visible .sls__text-body { transition: opacity 1s ease-out 0.4s, transform 1s ease-out 0.4s; }
  #{{ section_id }}.is-visible .sls__dots { transition: opacity 1s ease-out 0.55s, transform 1s ease-out 0.55s; }
  #{{ section_id }}.is-visible .sls__media { transition: opacity 1.2s cubic-bezier(0.25,0.1,0,1) 0.1s, transform 1.2s cubic-bezier(0.25,0.1,0,1) 0.1s; }

  #{{ section_id }} .sls__empty {
    padding: 48px 24px;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: {{ text_color }};
    opacity: 0.5;
    border: 1px dashed rgba({{ dot_r }},{{ dot_g }},{{ dot_b }},0.2);
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .sls__eyebrow,
    #{{ section_id }} .sls__heading,
    #{{ section_id }} .sls__text-body,
    #{{ section_id }} .sls__dots,
    #{{ section_id }} .sls__media,
    #{{ section_id }} .sls__media img {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
      animation: none !important;
    }
    #{{ section_id }} .sls__eyebrow { opacity: 0.5 !important; }
    #{{ section_id }} .sls__text-body { opacity: 0.75 !important; }
    #{{ section_id }} .sls__dot[data-state="active"] .sls__dot-fill { transform: scaleX(1) !important; }
  }
{%- endcapture -%}

<style>{{ section_css }}</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap">

<section
  id="{{ section_id }}"
  class="sls"
  aria-labelledby="{{ section_id }}-heading"
  data-sls-autoplay="{% if autoplay %}true{% else %}false{% endif %}"
  data-sls-interval="{{ interval_ms }}"
>
  <div class="sls__inner">
    {%- if section.blocks.size == 0 -%}
      <div class="sls__empty">Ajoutez des slides dans les réglages de la section.</div>
    {%- else -%}
      {%- assign first_block = section.blocks.first -%}

      <div class="sls__text">
        {%- if eyebrow != blank -%}
          <span class="sls__eyebrow">{{ eyebrow }}</span>
        {%- endif -%}

        <{{ heading_tag }} id="{{ section_id }}-heading" class="sls__heading" data-sls-heading>
          {{ first_block.settings.title }}
        </{{ heading_tag }}>

        <div class="sls__text-body" data-sls-body>
          {{ first_block.settings.text }}
        </div>

        <div class="sls__dots" role="tablist" aria-label="Navigation des slides">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="sls__dot"
              data-sls-dot="{{ forloop.index0 }}"
              data-state="{% if forloop.first %}active{% else %}idle{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Slide {{ forloop.index }} : {{ block.settings.title | strip_html | escape }}"
            >
              <span class="sls__dot-fill"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="sls__media">
        {%- if first_block.settings.image != blank -%}
          {%- assign fi = first_block.settings.image -%}
          <img
            data-sls-image
            src="{{ fi | image_url: width: 1200 }}"
            srcset="{{ fi | image_url: width: 600 }} 600w, {{ fi | image_url: width: 900 }} 900w, {{ fi | image_url: width: 1200 }} 1200w, {{ fi | image_url: width: 1600 }} 1600w"
            sizes="(min-width: 1024px) 50vw, 100vw"
            alt="{{ first_block.settings.image_alt | default: first_block.settings.title | strip_html | escape }}"
            width="{{ fi.width }}"
            height="{{ fi.height }}"
            loading="lazy"
            decoding="async"
          >
        {%- endif -%}
      </div>

      {%- comment -%} Données des slides pour le JS {%- endcomment -%}
      <script type="application/json" data-sls-slides>
      [
        {%- for block in section.blocks -%}
          {%- assign img = block.settings.image -%}
          {
            "title": {{ block.settings.title | strip_html | json }},
            "text": {{ block.settings.text | json }},
            "alt": {{ block.settings.image_alt | default: block.settings.title | strip_html | json }}
            {%- if img != blank -%},
            "src": {{ img | image_url: width: 1200 | json }},
            "srcset": "{{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 900 }} 900w, {{ img | image_url: width: 1200 }} 1200w, {{ img | image_url: width: 1600 }} 1600w",
            "width": {{ img.width }},
            "height": {{ img.height }}
            {%- endif -%}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
      </script>
    {%- endif -%}
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Reveal
  if ('IntersectionObserver' in window && !reduce) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) { section.classList.add('is-visible'); io.disconnect(); }
      });
    }, { threshold: 0.15 });
    io.observe(section);
  } else {
    section.classList.add('is-visible');
  }

  var slidesNode = section.querySelector('[data-sls-slides]');
  if (!slidesNode) return;

  var slides;
  try { slides = JSON.parse(slidesNode.textContent); } catch(e) { return; }
  if (!slides || slides.length === 0) return;

  var headingEl = section.querySelector('[data-sls-heading]');
  var bodyEl = section.querySelector('[data-sls-body]');
  var imgEl = section.querySelector('[data-sls-image]');
  var dots = section.querySelectorAll('[data-sls-dot]');
  var autoplay = section.getAttribute('data-sls-autoplay') === 'true' && slides.length > 1 && !reduce;
  var interval = parseInt(section.getAttribute('data-sls-interval'), 10) || 5000;

  var active = 0;
  var timer = null;
  var switching = false;

  function setSlide(idx){
    if (switching || idx === active) return;
    switching = true;

    if (headingEl) headingEl.classList.add('is-switching');
    if (bodyEl) bodyEl.classList.add('is-switching');
    if (imgEl) imgEl.classList.add('is-switching');

    setTimeout(function(){
      var s = slides[idx];
      if (headingEl) headingEl.textContent = s.title;
      if (bodyEl) bodyEl.innerHTML = s.text;
      if (imgEl && s.src) {
        imgEl.src = s.src;
        if (s.srcset) imgEl.srcset = s.srcset;
        imgEl.alt = s.alt || '';
      }

      active = idx;
      updateDots();

      // Fin du switch visuel
      requestAnimationFrame(function(){
        if (headingEl) headingEl.classList.remove('is-switching');
        if (bodyEl) bodyEl.classList.remove('is-switching');
        if (imgEl) imgEl.classList.remove('is-switching');
        switching = false;
      });
    }, 400);
  }

  function updateDots(){
    for (var i = 0; i < dots.length; i++) {
      if (i < active) {
        dots[i].setAttribute('data-state', 'done');
        dots[i].setAttribute('aria-selected', 'false');
      } else if (i === active) {
        // Force reflow pour redémarrer l'animation CSS
        dots[i].setAttribute('data-state', 'idle');
        void dots[i].offsetWidth;
        dots[i].setAttribute('data-state', 'active');
        dots[i].setAttribute('aria-selected', 'true');
      } else {
        dots[i].setAttribute('data-state', 'idle');
        dots[i].setAttribute('aria-selected', 'false');
      }
    }
  }

  function next(){
    setSlide((active + 1) % slides.length);
  }

  function startAutoplay(){
    if (!autoplay) return;
    stopAutoplay();
    timer = setInterval(next, interval);
  }
  function stopAutoplay(){
    if (timer) { clearInterval(timer); timer = null; }
  }

  // Click sur dot
  for (var i = 0; i < dots.length; i++) {
    (function(idx){
      dots[idx].addEventListener('click', function(){
        setSlide(idx);
        if (autoplay) startAutoplay();
      });
    })(i);
  }

  // Pause autoplay sur hover
  section.addEventListener('mouseenter', stopAutoplay);
  section.addEventListener('mouseleave', startAutoplay);

  // Pause quand la section n'est pas visible
  if ('IntersectionObserver' in window) {
    var visIO = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) startAutoplay();
        else stopAutoplay();
      });
    }, { threshold: 0.3 });
    visIO.observe(section);
  } else {
    startAutoplay();
  }
})();
</script>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  {% if eyebrow != blank %}"name": {{ eyebrow | strip_html | json }},{% endif %}
  "numberOfItems": {{ section.blocks.size }},
  "itemListElement": [
    {%- for block in section.blocks -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "item": {
          "@type": "Article",
          "headline": {{ block.settings.title | strip_html | json }},
          "description": {{ block.settings.text | strip_html | json }}
          {%- if block.settings.image != blank -%},
          "image": {{ block.settings.image | image_url: width: 1600 | prepend: 'https:' | json }}
          {%- endif -%}
        }
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Slider split",
  "tag": "section",
  "class": "section-slider-split",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Contenu" },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre", "default": "<p>Savoir-faire</p>" },
    {
      "type": "select", "id": "heading_tag", "label": "Balise HTML du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h1", "label": "H1" }
      ],
      "default": "h2"
    },

    { "type": "header", "content": "Autoplay" },
    { "type": "checkbox", "id": "autoplay", "label": "Défilement automatique", "default": true },
    { "type": "range", "id": "interval_seconds", "label": "Intervalle (secondes)", "min": 3, "max": 15, "step": 1, "unit": "s", "default": 5 },

    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "image_position", "label": "Position de l'image (desktop)",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "right"
    },
    {
      "type": "select", "id": "image_ratio", "label": "Ratio des images",
      "options": [
        { "value": "4/3", "label": "4:3 (par défaut)" },
        { "value": "3/2", "label": "3:2" },
        { "value": "1/1", "label": "1:1 (carré)" },
        { "value": "3/4", "label": "3:4 (portrait)" },
        { "value": "16/9", "label": "16:9" }
      ],
      "default": "4/3"
    },

    { "type": "header", "content": "Typographie titre" },
    { "type": "range", "id": "heading_size_min", "label": "Taille min (mobile)", "min": 16, "max": 48, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "heading_size_vw", "label": "Taille fluide", "min": 2, "max": 8, "step": 1, "unit": "vw", "default": 3 },
    { "type": "range", "id": "heading_size_max", "label": "Taille max (desktop)", "min": 24, "max": 80, "step": 2, "unit": "px", "default": 42 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "bg_color", "label": "Fond de section", "default": "#3D4030" },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur sur-titre", "default": "#EEECE5" },
    { "type": "color", "id": "heading_color", "label": "Couleur titre", "default": "#EEECE5" },
    { "type": "color", "id": "text_color", "label": "Couleur paragraphe", "default": "#EEECE5" },
    { "type": "color", "id": "dot_color", "label": "Couleur des barres de progression", "default": "#EEECE5" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Texte alternatif (alt)", "info": "Important pour le SEO. Décrit l'image. Si vide, utilise le titre." },
        { "type": "text", "id": "title", "label": "Titre du slide", "default": "Des matériaux nobles." },
        { "type": "richtext", "id": "text", "label": "Texte du slide", "default": "<p>Mousses haute résilience, tissus certifiés Oeko-Tex, bois issus de forêts gérées durablement. Nous ne transigeons sur rien.</p>" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Slider split",
      "category": "Contenu",
      "blocks": [
        { "type": "slide", "settings": { "title": "Des matériaux nobles.", "text": "<p>Mousses haute résilience, tissus certifiés Oeko-Tex, bois issus de forêts gérées durablement. Nous ne transigeons sur rien.</p>" } },
        { "type": "slide", "settings": { "title": "Un savoir-faire artisanal.", "text": "<p>Chaque pièce est assemblée à la main dans nos ateliers partenaires, sélectionnés pour leur maîtrise technique et leur exigence.</p>" } },
        { "type": "slide", "settings": { "title": "Un contrôle absolu.", "text": "<p>Du prototype à la livraison, chaque étape suit un cahier des charges rigoureux. Rien ne quitte l'atelier sans validation.</p>" } }
      ]
    }
  ]
}
{% endschema %}
