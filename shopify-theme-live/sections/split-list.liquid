{%- liquid
  assign section_id = 'split-list-' | append: section.id
  assign options = section.settings

  assign image = options.image
  assign image_alt = options.image_alt

  assign eyebrow = options.eyebrow
  assign heading = options.heading
  assign heading_tag = options.heading_tag | default: 'h2'
  assign paragraph = options.paragraph

  assign image_position = options.image_position | default: 'left'
  assign image_ratio = options.image_ratio | default: '4/5'

  assign bg_color = options.bg_color | default: '#FFFFFF'
  assign eyebrow_color = options.eyebrow_color | default: '#000000'
  assign heading_color = options.heading_color | default: '#000000'
  assign text_color = options.text_color | default: '#000000'
  assign label_color = options.label_color | default: '#000000'

  assign heading_min = options.heading_size_min | default: 32
  assign heading_vw = options.heading_size_vw | default: 4
  assign heading_max = options.heading_size_max | default: 52
-%}

{%- capture section_css -%}
  /* py-8 md:py-12 px-4 md:px-6 xl:px-8 */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding: 32px 16px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} { padding: 48px 24px; }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} { padding-left: 32px; padding-right: 32px; }
  }

  #{{ section_id }} .spl__inner {
    max-width: 1760px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    #{{ section_id }} .spl__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 64px;
    }
  }

  #{{ section_id }} .spl__text,
  #{{ section_id }} .spl__media {
    width: 100%;
    min-width: 0;
  }

  {% if image_position == 'right' %}
    @media (min-width: 1024px) {
      #{{ section_id }} .spl__media { order: 2; }
      #{{ section_id }} .spl__text { order: 1; }
    }
  {% endif %}

  /* Image : ratio 4/5, reveal */
  #{{ section_id }} .spl__media {
    overflow: hidden;
    background-color: #F5F3EE;
    aspect-ratio: {{ image_ratio }};
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1.2s cubic-bezier(0.25,0.1,0,1), transform 1.2s cubic-bezier(0.25,0.1,0,1);
  }
  #{{ section_id }}.is-visible .spl__media { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .spl__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Texte column */
  #{{ section_id }} .spl__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Eyebrow : Poppins 400 11px tracking 0.2em noir/40 mb-4 */
  #{{ section_id }} .spl__eyebrow {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 11px;
    text-transform: uppercase;
    color: {{ eyebrow_color }};
    opacity: 0;
    transform: translateY(20px);
    margin-bottom: 16px;
    line-height: 1;
    transition: opacity 1s ease-out 0.1s, transform 1s ease-out 0.1s;
  }
  #{{ section_id }}.is-visible .spl__eyebrow { opacity: 0.4; transform: translateY(0); }
  #{{ section_id }} .spl__eyebrow * { margin: 0; color: inherit; font-family: inherit; }

  /* Titre : ST Nova Sans 400 clamp(32,4vw,52) leading-none mb-8 */
  #{{ section_id }} .spl__heading {
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-weight: 400;
    line-height: 1;
    color: {{ heading_color }};
    font-size: clamp({{ heading_min }}px, {{ heading_vw }}vw, {{ heading_max }}px);
    margin: 0 0 32px 0;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 1.1s ease-out 0.25s, transform 1.1s ease-out 0.25s;
  }
  #{{ section_id }}.is-visible .spl__heading { opacity: 1; transform: translateY(0); }
  #{{ section_id }} .spl__heading * { font-family: inherit; font-weight: inherit; color: inherit; margin: 0; }

  /* Paragraphe : Poppins 300 15px noir/65 max-w-lg leading-relaxed mb-8 */
  #{{ section_id }} .spl__paragraph {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.65;
    color: {{ text_color }};
    max-width: 520px;
    margin: 0 0 32px 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out 0.45s, transform 1s ease-out 0.45s;
  }
  #{{ section_id }}.is-visible .spl__paragraph { opacity: 0.65; transform: translateY(0); }
  #{{ section_id }} .spl__paragraph * { margin: 0; color: inherit; font-family: inherit; }
  #{{ section_id }} .spl__paragraph a { color: inherit; text-decoration: underline; }

  /* Liste des items */
  #{{ section_id }} .spl__list {
    display: flex;
    flex-direction: column;
    padding-left: 0;
    margin: 0;
    list-style: none;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease-out 0.6s, transform 1s ease-out 0.6s;
  }
  #{{ section_id }}.is-visible .spl__list { opacity: 1; transform: translateY(0); }

  #{{ section_id }} .spl__item {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid rgba({{ label_color | color_extract: 'red' }},{{ label_color | color_extract: 'green' }},{{ label_color | color_extract: 'blue' }},0.06);
  }
  #{{ section_id }} .spl__item:last-child { border-bottom: none; }

  /* Label : ST Nova Sans 400 13px tracking 0.1em, largeur fixe 112px */
  #{{ section_id }} .spl__label {
    flex-shrink: 0;
    width: 112px;
    font-family: 'ST Nova Sans', 'Big Shoulders Display', sans-serif;
    font-weight: 400;
    font-size: 13px;
    text-transform: uppercase;
    color: {{ label_color }};
    line-height: 1.3;
  }

  /* Description : Poppins 300 13px noir/50 */
  #{{ section_id }} .spl__desc {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 13px;
    color: {{ text_color }};
    opacity: 0.5;
    line-height: 1.5;
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .spl__media,
    #{{ section_id }} .spl__eyebrow,
    #{{ section_id }} .spl__heading,
    #{{ section_id }} .spl__paragraph,
    #{{ section_id }} .spl__list {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    #{{ section_id }} .spl__eyebrow { opacity: 0.4 !important; }
    #{{ section_id }} .spl__paragraph { opacity: 0.65 !important; }
  }
{%- endcapture -%}

<style>{{ section_css }}</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap">

<section id="{{ section_id }}" class="spl" aria-labelledby="{{ section_id }}-heading">
  <div class="spl__inner">
    <div class="spl__media">
      {%- if image != blank -%}
        <img
          src="{{ image | image_url: width: 1200 }}"
          srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1600 }} 1600w"
          sizes="(min-width: 1024px) 50vw, 100vw"
          alt="{{ image_alt | default: image.alt | default: heading | strip_html | escape }}"
          width="{{ image.width }}"
          height="{{ image.height }}"
          loading="lazy"
          decoding="async"
        >
      {%- endif -%}
    </div>

    <div class="spl__text">
      {%- if eyebrow != blank -%}
        <span class="spl__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}

      {%- if heading != blank -%}
        <{{ heading_tag }} id="{{ section_id }}-heading" class="spl__heading">{{ heading }}</{{ heading_tag }}>
      {%- endif -%}

      {%- if paragraph != blank -%}
        <div class="spl__paragraph">{{ paragraph }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="spl__list" role="list">
          {%- for block in section.blocks -%}
            <li class="spl__item" {{ block.shopify_attributes }}>
              <span class="spl__label">{{ block.settings.label }}</span>
              <span class="spl__desc">{{ block.settings.description }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if ('IntersectionObserver' in window && !reduce) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) { section.classList.add('is-visible'); io.disconnect(); }
      });
    }, { threshold: 0.15 });
    io.observe(section);
  } else {
    section.classList.add('is-visible');
  }
})();
</script>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  {% if heading != blank %}"name": {{ heading | strip_html | json }},{% endif %}
  {% if paragraph != blank %}"description": {{ paragraph | strip_html | json }},{% endif %}
  "numberOfItems": {{ section.blocks.size }},
  "itemListElement": [
    {%- for block in section.blocks -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "item": {
          "@type": "Thing",
          "name": {{ block.settings.label | strip_html | json }},
          "description": {{ block.settings.description | strip_html | json }}
        }
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Split list",
  "tag": "section",
  "class": "section-split-list",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif (alt)", "info": "Important pour le SEO. Si vide, utilise le titre." },
    {
      "type": "select", "id": "image_ratio", "label": "Ratio de l'image",
      "options": [
        { "value": "4/5", "label": "4:5 (portrait, par défaut)" },
        { "value": "3/4", "label": "3:4" },
        { "value": "1/1", "label": "1:1 (carré)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" }
      ],
      "default": "4/5"
    },
    {
      "type": "select", "id": "image_position", "label": "Position de l'image (desktop)",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },

    { "type": "header", "content": "Contenu" },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre", "default": "<p>Nos engagements</p>" },
    { "type": "richtext", "id": "heading", "label": "Titre", "default": "<p>Nos engagements.</p>" },
    {
      "type": "select", "id": "heading_tag", "label": "Balise HTML du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h1", "label": "H1" }
      ],
      "default": "h2"
    },
    { "type": "richtext", "id": "paragraph", "label": "Paragraphe d'introduction", "default": "<p>Chaque pièce SQUARE est pensée pour traverser les années. Nous ne fabriquons pas du mobilier jetable. Nous sélectionnons nos ateliers, contrôlons chaque finition, et nous engageons sur deux ans.</p>" },

    { "type": "header", "content": "Typographie titre" },
    { "type": "range", "id": "heading_size_min", "label": "Taille min (mobile)", "min": 20, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "heading_size_vw", "label": "Taille fluide", "min": 2, "max": 8, "step": 1, "unit": "vw", "default": 4 },
    { "type": "range", "id": "heading_size_max", "label": "Taille max (desktop)", "min": 30, "max": 100, "step": 2, "unit": "px", "default": 52 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "bg_color", "label": "Fond de section", "default": "#FFFFFF" },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur sur-titre", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Couleur titre", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Couleur texte", "default": "#000000" },
    { "type": "color", "id": "label_color", "label": "Couleur des labels", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "LIVRAISON" },
        { "type": "text", "id": "description", "label": "Description", "default": "Sur rendez-vous, à l'étage, par notre logisticien partenaire" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Split list",
      "category": "Contenu",
      "blocks": [
        { "type": "item", "settings": { "label": "LIVRAISON", "description": "Sur rendez-vous, à l'étage, par notre logisticien partenaire" } },
        { "type": "item", "settings": { "label": "GARANTIE", "description": "Deux ans, sur l'ensemble du catalogue" } },
        { "type": "item", "settings": { "label": "PAIEMENT", "description": "En trois fois, sans frais ni dossier" } },
        { "type": "item", "settings": { "label": "SAVOIR-FAIRE", "description": "Ateliers partenaires sélectionnés pour leur exigence" } }
      ]
    }
  ]
}
{% endschema %}
