    { "type": "text", "id": "rating_count", "label": "Texte sous les étoiles", "default": "2 avis vérifiés" },
    { "type": "header", "content": "Bouton" },
    { "type": "text", "id": "cta_label", "label": "Texte du bouton", "default": "écrire un avis" },
    { "type": "url", "id": "cta_link", "label": "Lien du bouton" },
    { "type": "header", "content": "Marges" },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Marge supérieure — mobile",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Marge inférieure — mobile",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Marge supérieure — desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Marge inférieure — desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Avis",
      "settings": [
        { "type": "text", "id": "name", "label": "Nom", "default": "Sophie M." },
        { "type": "text", "id": "location", "label": "Ville", "default": "Paris 11e" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Témoignage",
          "default": "Le YOKO est exactement ce qu'on cherchait pour notre salon de 25m². La modularité est un vrai plus — on change la configuration selon les soirées."
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Étoiles",
          "min": 1, "max": 5, "step": 1, "default": 5
        },
        { "type": "text", "id": "date", "label": "Date", "default": "Mars 2026" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Témoignages",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "name": "Sophie M.",
            "location": "Paris 11e",
            "text": "Le YOKO est exactement ce qu'on cherchait pour notre salon de 25m². La modularité est un vrai plus — on change la configuration selon les soirées. Le tissu est doux et résistant, même avec notre chat.",
            "stars": 5,
            "date": "Mars 2026"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Thomas & Léa",
            "location": "Lyon 6e",
            "text": "Très beau canapé, confortable dès la livraison. On a pris le coloris Mousse de Boulogne, magnifique en lumière naturelle. Seul bémol : le délai de livraison un peu long, mais ça vaut l'attente.",
            "stars": 4,
            "date": "Février 2026"
          }
        }
      ]
    }
  ]
}
