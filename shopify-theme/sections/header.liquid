<script>
(function() {
  var header = document.getElementById('{{ section_id }}');
  if (!header) return;

  function tryOpenSwymDrawer() {
    var selectors = [
      '#notepad-anchor-title',
      '#swym-anchor #notepad-anchor-title',
      '#swym-anchor a',
      '#swym-anchor',
      '#swym-plugin a',
      '#swym-plugin'
    ];

    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (!el) continue;

      el.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));
      el.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }));
      if (typeof el.click === 'function') {
        el.click();
      } else {
        el.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
      }
      return true;
    }

    return false;
  }

  /* Pré-enregistre l'ouverture via la queue officielle SwymCallbacks pour les chargements tardifs */
  window.SwymCallbacks = window.SwymCallbacks || [];

  /* Délégation : capte tous les liens [data-swym-open] (header desktop ET drawer mobile) */
  document.addEventListener('click', function(event) {
    var trigger = event.target.closest && event.target.closest('[data-swym-open]');
    if (!trigger) return;

    event.preventDefault();

    if (tryOpenSwymDrawer()) return;

    /* Swym peut se charger après le header: on retente brièvement avant fallback */
    var attempts = 0;
    var maxAttempts = 12;
    var timer = window.setInterval(function() {
      attempts += 1;
      if (tryOpenSwymDrawer()) {
        window.clearInterval(timer);
        return;
      }
      if (attempts >= maxAttempts) {
        window.clearInterval(timer);
        window.location.href = '/pages/wishlist';
      }
    }, 250);
  });

  var enableTransparent = header.dataset.enableTransparent === 'true';
  var state = 'top';
  var lastScrollY = window.scrollY;
  var accumulatedUp = 0, accumulatedDown = 0, ticking = false;
  var DIRECTION_THRESHOLD = 10, TOP_THRESHOLD = 50, TRANSPARENT_THRESHOLD = 5;

  function setState(newState) {
    if (state === newState) return;
    state = newState;
    header.classList.remove('is-sticky', 'is-hidden');
    if (newState === 'hidden') header.classList.add('is-sticky', 'is-hidden');
    else if (newState === 'visible') header.classList.add('is-sticky');
  }

  function update() {
    var scrollY = window.scrollY;
    var delta = scrollY - lastScrollY;
    if (enableTransparent) {
      if (scrollY <= TRANSPARENT_THRESHOLD) header.classList.add('is-transparent');
      else header.classList.remove('is-transparent');
    }
    if (scrollY <= TOP_THRESHOLD) {
      setState('top'); accumulatedUp = 0; accumulatedDown = 0;
      lastScrollY = scrollY; ticking = false; return;
    }
    if (delta > 0) {
      accumulatedDown += delta; accumulatedUp = 0;
      if (accumulatedDown > DIRECTION_THRESHOLD) setState('hidden');
    } else if (delta < 0) {
      accumulatedUp += -delta; accumulatedDown = 0;
      if (accumulatedUp > DIRECTION_THRESHOLD) setState('visible');
    }
    lastScrollY = scrollY; ticking = false;
  }

  window.addEventListener('scroll', function() {
    if (!ticking) { window.requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
  update();
})();
</script>

