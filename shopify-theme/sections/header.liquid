{%- comment -%}
  ============================================
  Section: Header v6
  - Snippet externe : snippets/header-drawer.liquid
  - Icônes SVG inline (pas de dépendance icon-*)
  - State machine anti-jitter Lenis
  ============================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign section_id = 'header-' | append: section.id

  assign is_home = false
  if template.name == 'index' or request.path == '/'
    assign is_home = true
  endif

  assign is_collection = false
  if template.name == 'collection'
    assign is_collection = true
  endif

  assign enable_transparent = false
  if s.enable_transparent_on_home and is_home
    assign enable_transparent = true
  endif
  if s.enable_transparent_on_collection and is_collection
    assign enable_transparent = true
  endif
-%}

<style>
  /* Swym: on garde le launcher dans le DOM et cliquable (programmatique),
     mais hors champ visuel. Pas de display:none ni pointer-events:none
     sinon le handler interne de Swym ne s'exécute pas. */
  #swym-plugin {
    position: fixed !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
    opacity: 0 !important;
    z-index: -1 !important;
  }
  #swym-anchor {
    transform: scale(0.01) !important;
    transform-origin: bottom right !important;
  }

  :root {
    --header-height-mobile: {{ s.height_mobile }}px;
    --header-height-desktop: {{ s.height_desktop }}px;
  }

  #{{ section_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: var(--header-height-mobile);
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    background-color: {{ s.bg_color }};
    color: {{ s.text_color }};
    border-bottom: 1px solid {{ s.border_color }};
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition:
      background-color 400ms ease,
      color 400ms ease,
      border-color 400ms ease,
      transform 350ms ease-out,
      backdrop-filter 400ms ease;
  }

  @media (min-width: 990px) {
    #{{ section_id }} { height: var(--header-height-desktop); }
  }

  #{{ section_id }}.is-transparent {
    background-color: transparent;
    color: {{ s.text_color_transparent }};
    border-bottom-color: transparent;
    -webkit-backdrop-filter: blur(0);
    backdrop-filter: blur(0);
  }

  #{{ section_id }}.is-sticky { position: fixed; top: 0; }
  #{{ section_id }}.is-hidden { transform: translateY(-100%); }

  #{{ section_id }} .header__inner {
    width: 100%;
    max-width: {{ s.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    gap: 16px;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .header__inner { padding: 0 24px; }
  }
  @media (min-width: 1280px) {
    #{{ section_id }} .header__inner { padding: 0 32px; }
  }

  #{{ section_id }} .header__nav {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 28px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    #{{ section_id }} .header__nav { display: flex; }
  }
  #{{ section_id }} .header__nav-link {
    font-family: var(--font-body-family);
    font-weight: 300;
    font-size: 11px;
    text-transform: uppercase;
    color: inherit;
    text-decoration: none;
    transition: opacity 300ms ease;
    white-space: nowrap;
    line-height: 1;
  }
  #{{ section_id }} .header__nav-link:hover,
  #{{ section_id }} .header__nav-link:focus-visible { opacity: 0.6; outline: none; }

  #{{ section_id }} .header__burger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 8px;
    margin-left: -8px;
    color: inherit;
    cursor: pointer;
    transition: opacity 300ms ease;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }
  #{{ section_id }} .header__burger:hover,
  #{{ section_id }} .header__burger:focus-visible { opacity: 0.6; outline: none; }
  @media (min-width: 1024px) {
    #{{ section_id }} .header__burger { display: none !important; }
  }
  #{{ section_id }} .header__burger svg { width: 22px; height: 22px; }

  #{{ section_id }} .header__logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    text-decoration: none;
    color: inherit;
    margin: 0;
    padding: 0;
    z-index: 1;
  }
  #{{ section_id }} .header__logo img {
    display: block;
    height: {{ s.logo_height_mobile }}px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    grid-area: 1 / 1;
    transition: opacity 400ms ease;
  }
  @media (min-width: 768px) {
    #{{ section_id }} .header__logo img { height: {{ s.logo_height_desktop }}px; }
  }
  #{{ section_id }} .header__logo-transparent { opacity: 0; }
  #{{ section_id }}.is-transparent .header__logo-default { opacity: 0; }
  #{{ section_id }}.is-transparent .header__logo-transparent { opacity: 1; }

  #{{ section_id }} .header__actions {
    display: flex;
    align-items: center;
    gap: 20px;
    color: inherit;
    flex-shrink: 0;
    margin-left: auto;
    position: relative;
    z-index: 2;
  }
  #{{ section_id }} .header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 4px;
    color: inherit;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 300ms ease;
    position: relative;
  }
  #{{ section_id }} .header__action:hover,
  #{{ section_id }} .header__action:focus-visible { opacity: 0.6; outline: none; }
  #{{ section_id }} .header__action svg { width: 20px; height: 20px; }
  #{{ section_id }} .header__action--hide-mobile { display: none; }
  @media (min-width: 768px) {
    #{{ section_id }} .header__action--hide-mobile { display: flex; }
  }
  #{{ section_id }} .header__cart-count {
    position: absolute;
    top: -4px;
    right: -6px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background-color: {{ s.cart_badge_bg }};
    color: {{ s.cart_badge_color }};
    font-family: var(--font-body-family);
    font-size: 9px;
    font-weight: 500;
    line-height: 16px;
    text-align: center;
    border-radius: 50%;
    pointer-events: none;
  }
  #{{ section_id }} .header__cart-count[data-count="0"] { display: none; }
  #{{ section_id }} .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  #{{ section_id }} a:focus-visible,
  #{{ section_id }} button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }}, #{{ section_id }} * { transition: none !important; }
  }
</style>

<header id="{{ section_id }}" class="header{% if enable_transparent %} is-transparent{% endif %}" role="banner" data-enable-transparent="{{ enable_transparent }}">
  <div class="header__inner">

    <button type="button" class="header__burger" aria-label="Ouvrir le menu" aria-controls="header-drawer" aria-expanded="false" data-drawer-open>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="7" x2="21" y2="7"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="17" x2="21" y2="17"/>
      </svg>
    </button>

    {%- if s.menu != blank -%}
      <nav role="navigation" aria-label="Navigation principale">
        <ul class="header__nav" role="list">
          {%- for link in s.menu.links -%}
            <li>
              <a href="{{ link.url }}" class="header__nav-link"{% if link.current %} aria-current="page"{% endif %}>
                {{ link.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name | escape }} — Accueil">
      {%- if s.logo_default != blank -%}
        <img class="header__logo-default"
          src="{{ s.logo_default | image_url: width: 800 }}"
          srcset="{{ s.logo_default | image_url: width: 200 }} 200w, {{ s.logo_default | image_url: width: 400 }} 400w, {{ s.logo_default | image_url: width: 600 }} 600w, {{ s.logo_default | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) {{ s.logo_height_mobile | times: 4 }}px, {{ s.logo_height_desktop | times: 4 }}px"
          alt="{{ shop.name | escape }}"
          width="{{ s.logo_default.width }}" height="{{ s.logo_default.height }}"
          loading="eager" fetchpriority="high" decoding="async">
      {%- else -%}
        <span style="font-family: var(--font-heading-family); font-size: 24px;">{{ shop.name | escape }}</span>
      {%- endif -%}
      {%- if s.logo_transparent != blank -%}
        <img class="header__logo-transparent"
          src="{{ s.logo_transparent | image_url: width: 800 }}"
          srcset="{{ s.logo_transparent | image_url: width: 200 }} 200w, {{ s.logo_transparent | image_url: width: 400 }} 400w, {{ s.logo_transparent | image_url: width: 600 }} 600w, {{ s.logo_transparent | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) {{ s.logo_height_mobile | times: 4 }}px, {{ s.logo_height_desktop | times: 4 }}px"
          alt="{{ shop.name | escape }}"
          width="{{ s.logo_transparent.width }}" height="{{ s.logo_transparent.height }}"
          loading="eager" fetchpriority="high" decoding="async">
      {%- endif -%}
    </a>

    <div class="header__actions">
      {%- if s.show_search -%}
        <button type="button" class="header__action" aria-label="Rechercher" data-search-toggle>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <line x1="21" y1="21" x2="16.5" y2="16.5"/>
          </svg>
        </button>
      {%- endif -%}

      {%- if s.show_header_wishlist -%}
        <a href="/pages/wishlist" class="header__action header__action--hide-mobile" aria-label="Ma wishlist" data-swym-open>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 17.5s-7-4.5-7-9a3.5 3.5 0 0 1 6.5-1.8L10 8l.5-1.3A3.5 3.5 0 0 1 17 8.5c0 4.5-7 9-7 9z"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__action header__action--hide-mobile" aria-label="{%- if customer -%}Mon compte{%- else -%}Se connecter{%- endif -%}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
          </svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" id="cart-icon-bubble" class="header__action" aria-label="Panier ({{ cart.item_count }})">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="header__cart-count" data-count="{{ cart.item_count }}" aria-hidden="true">{{ cart.item_count }}</span>
        <span class="visually-hidden">{{ cart.item_count }} articles dans le panier</span>
      </a>
    </div>
  </div>
</header>

{% render 'header-drawer', section: section %}

{%- comment -%} ─── Desktop Predictive Search Overlay ─── {%- endcomment -%}
{%- liquid
  assign popular_raw = s.popular_searches | default: "Canapé d'angle\nTable à manger\nFauteuil bouclette\nLit coffre\nTapis berbère"
  assign popular_list = popular_raw | newline_to_br | split: '<br />'
  assign featured_collection = s.search_featured_collection
  if featured_collection == blank or featured_collection.products.size == 0
    assign featured_collection = collections.frontpage
  endif
  assign search_logo = s.search_logo | default: s.logo_default
-%}

<style>
  /* Predictive search desktop — design fidèle Lovable */
  #{{ section_id }}-search,
  #{{ section_id }}-search * { box-sizing: border-box; }

  #{{ section_id }}-search {
    --psq-noir: #0F0F0F;
    --psq-creme: #F5F1EA;
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    visibility: hidden;
  }
  #{{ section_id }}-search.is-open { pointer-events: auto; visibility: visible; }

  .psq__backdrop {
    position: absolute; inset: 0;
    background: rgba(15,15,15,0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  #{{ section_id }}-search.is-open .psq__backdrop { opacity: 1; }

  .psq__panel {
    position: absolute;
    top: 0; left: 0; right: 0;
    background: #fff;
    color: var(--psq-noir);
    transform: translateY(-100%);
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    max-height: 92vh;
    overflow-y: auto;
    font-family: 'Poppins', sans-serif;
  }
  #{{ section_id }}-search.is-open .psq__panel { transform: translateY(0); }

  .psq__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 24px;
  }
  @media (min-width: 1280px) { .psq__inner { padding: 24px 32px; } }

  .psq__top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    margin-bottom: 16px;
  }
  .psq__kicker {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(15,15,15,0.5);
    justify-self: start;
  }
  .psq__logo {
    justify-self: center;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .psq__logo img {
    display: block;
    height: {{ s.search_logo_height_mobile | default: 56 }}px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }
  @media (min-width: 768px) {
    .psq__logo img { height: {{ s.search_logo_height_desktop | default: 72 }}px; }
  }
  .psq__close {
    background: none; border: 0; padding: 4px;
    color: rgba(15,15,15,0.6);
    cursor: pointer; line-height: 0;
    transition: color 0.2s ease;
    justify-self: end;
  }
  .psq__close:hover { color: var(--psq-noir); }

  .psq__field { position: relative; }
  .psq__field-icon {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    color: rgba(15,15,15,0.4); pointer-events: none; line-height: 0;
  }
  .psq__input {
    width: 100%;
    background: rgba(245,241,234,0.5);
    border: 1px solid rgba(15,15,15,0.08);
    padding: 10px 12px 10px 40px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    color: var(--psq-noir);
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    appearance: none;
    transition: border-color 0.2s ease;
  }
  .psq__input::placeholder { color: rgba(15,15,15,0.35); }
  /* Masquer le bouton "clear" natif (croix) des inputs type=search */
  .psq__input::-webkit-search-cancel-button,
  .psq__input::-webkit-search-decoration,
  .psq__input::-webkit-search-results-button,
  .psq__input::-webkit-search-results-decoration { -webkit-appearance: none; appearance: none; display: none; }
  .psq__input::-ms-clear,
  .psq__input::-ms-reveal { display: none; width: 0; height: 0; }
  .psq__input:focus,
  .psq__input:focus-visible {
    border-color: rgba(15,15,15,0.3);
    outline: none;
    box-shadow: none;
  }

  .psq__results { margin-top: 24px; display: grid; grid-template-columns: 1fr; gap: 32px; }
  @media (min-width: 768px) {
    .psq__results { grid-template-columns: 1fr 2fr; gap: 32px; }
  }
  #{{ section_id }}-search [hidden] { display: none !important; }

  .psq__col-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(15,15,15,0.4);
    display: block;
  }

  /* Empty state — popular searches */
  .psq__suggestions { margin-top: 16px; padding: 0; list-style: none; }
  .psq__suggestions li + li { border-top: 1px solid rgba(15,15,15,0.06); }
  .psq__suggestion-btn {
    width: 100%;
    display: flex; align-items: center; gap: 12px;
    padding: 10px 0;
    background: none; border: 0;
    text-align: left; cursor: pointer;
    color: rgba(15,15,15,0.75);
    font-family: 'Poppins', sans-serif; font-size: 12px;
    transition: color 0.2s ease;
  }
  .psq__suggestion-btn:hover { color: var(--psq-noir); }
  .psq__suggestion-btn svg { color: rgba(15,15,15,0.3); transition: color 0.2s ease; flex-shrink: 0; }
  .psq__suggestion-btn:hover svg { color: rgba(15,15,15,0.6); }

  /* Empty state — featured products */
  .psq__featured-grid {
    margin-top: 16px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 768px) { .psq__featured-grid { grid-template-columns: repeat(3, 1fr); } }
  .psq__featured-card { display: block; text-decoration: none; color: inherit; }
  .psq__featured-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(245,241,234,0.4);
  }
  .psq__featured-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s ease;
  }
  .psq__featured-card:hover .psq__featured-img img { transform: scale(1.05); }
  .psq__featured-name {
    margin-top: 8px;
    font-size: 11px; color: var(--psq-noir);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .psq__featured-price { font-size: 10px; color: rgba(15,15,15,0.5); }

  /* Query state — collections list */
  .psq__collections { margin-top: 12px; padding: 0; list-style: none; }
  .psq__collections li + li { margin-top: 8px; }
  .psq__collections a {
    font-size: 12px; color: rgba(15,15,15,0.75);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .psq__collections a:hover {
    color: var(--psq-noir);
    text-decoration: underline; text-underline-offset: 4px;
  }

  /* Query state — products grid */
  .psq__products-grid {
    margin-top: 12px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 768px) { .psq__products-grid { grid-template-columns: repeat(3, 1fr); } }

  /* Carte produit (style ALD) : image carrée, titre, prix dessous */
  .psq__product-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .psq__product-card-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(245,241,234,0.4);
  }
  .psq__product-card-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s ease;
  }
  .psq__product-card:hover .psq__product-card-img img { transform: scale(1.05); }
  .psq__product-card-name {
    margin-top: 8px;
    font-size: 12px; color: var(--psq-noir);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .psq__product-card-price { font-size: 11px; color: rgba(15,15,15,0.55); margin-top: 2px; }

  /* Ancienne disposition row (non utilisée mais conservée si besoin) */
  .psq__product-row {
    display: flex; align-items: center; gap: 12px;
    padding: 6px;
    text-decoration: none; color: inherit;
    transition: background 0.2s ease;
  }
  .psq__product-row:hover { background: rgba(245,241,234,0.4); }
  .psq__product-thumb {
    width: 48px; height: 48px; flex-shrink: 0;
    overflow: hidden;
    background: rgba(245,241,234,0.4);
  }
  .psq__product-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .psq__product-info { min-width: 0; flex: 1; }
  .psq__product-name {
    font-size: 11px; color: var(--psq-noir);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .psq__product-price { font-size: 10px; color: rgba(15,15,15,0.5); }

  .psq__empty {
    grid-column: 1 / -1;
    padding: 32px 0;
    text-align: center;
    font-size: 12px;
    color: rgba(15,15,15,0.45);
  }

  /* Mobile : panel plein écran, padding réduit */
  @media (max-width: 767px) {
    .psq__panel { max-height: 100vh; height: 100vh; }
    .psq__inner { padding: 16px; }
    .psq__kicker { visibility: hidden; }
    .psq__results { gap: 24px; }
    .psq__featured-grid { grid-template-columns: repeat(2, 1fr); }
    .psq__products-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
</style>

<div id="{{ section_id }}-search" class="psq" aria-hidden="true" role="dialog" aria-label="Recherche">
  <div class="psq__backdrop" data-search-close></div>
  <div class="psq__panel" role="document">
    <div class="psq__inner">
      <div class="psq__top">
        <span class="psq__kicker">Recherche</span>
        <a href="{{ routes.root_url }}" class="psq__logo" aria-label="{{ shop.name | escape }} — Accueil">
          {%- if search_logo != blank -%}
            <img src="{{ search_logo | image_url: width: 600 }}"
                 srcset="{{ search_logo | image_url: width: 300 }} 300w, {{ search_logo | image_url: width: 600 }} 600w"
                 sizes="288px"
                 alt="{{ shop.name | escape }}"
                 width="{{ search_logo.width }}" height="{{ search_logo.height }}"
                 loading="lazy" decoding="async">
          {%- else -%}
            <span style="font-family: var(--font-heading-family); font-size: 20px;">{{ shop.name | escape }}</span>
          {%- endif -%}
        </a>
        <button type="button" class="psq__close" aria-label="Fermer" data-search-close>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <form action="{{ routes.search_url }}" method="get" role="search" class="psq__field" data-search-form>
        <span class="psq__field-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/>
          </svg>
        </span>
        <input type="search" name="q" autocomplete="off" placeholder="Rechercher un produit, une pièce…" class="psq__input" data-search-input>
        <input type="hidden" name="options[prefix]" value="last">
      </form>

      {%- comment -%} Empty state — populated by Liquid, hidden when query is non-empty {%- endcomment -%}
      <div class="psq__results" data-search-empty>
        <div>
          <span class="psq__col-label">Recherches populaires</span>
          <ul class="psq__suggestions">
            {%- for term in popular_list -%}
              {%- assign t = term | strip -%}
              {%- if t != blank -%}
                <li>
                  <button type="button" class="psq__suggestion-btn" data-search-suggest="{{ t | escape }}">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                      <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/>
                    </svg>
                    <span>{{ t }}</span>
                  </button>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        {%- if featured_collection.products.size > 0 -%}
        <div>
          <span class="psq__col-label">Sélection du moment</span>
          <div class="psq__featured-grid">
            {%- for p in featured_collection.products limit: 3 -%}
              <a href="{{ p.url }}" class="psq__featured-card">
                <div class="psq__featured-img">
                  {%- if p.featured_image -%}
                    <img src="{{ p.featured_image | image_url: width: 400 }}"
                         srcset="{{ p.featured_image | image_url: width: 200 }} 200w, {{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 600 }} 600w"
                         sizes="(min-width: 768px) 200px, 50vw"
                         width="{{ p.featured_image.width }}"
                         height="{{ p.featured_image.height }}"
                         alt="{{ p.title | escape }}" loading="lazy" decoding="async">
                  {%- endif -%}
                </div>
                <div class="psq__featured-name">{{ p.title }}</div>
                <div class="psq__featured-price">{{ p.price | money }}</div>
              </a>
            {%- endfor -%}
          </div>
        </div>
        {%- endif -%}
      </div>

      {%- comment -%} Query state — populated by JS {%- endcomment -%}
      <div class="psq__results" data-search-query hidden>
        <div>
          <span class="psq__col-label">Collections</span>
          <ul class="psq__collections" data-search-collections></ul>
        </div>
        <div>
          <span class="psq__col-label">Produits</span>
          <div class="psq__products-grid" data-search-products></div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  var root = document.getElementById('{{ section_id }}-search');
  if (!root) return;
  var trigger = document.querySelector('#{{ section_id }} [data-search-toggle]');
  var input = root.querySelector('[data-search-input]');
  var emptyState = root.querySelector('[data-search-empty]');
  var queryState = root.querySelector('[data-search-query]');
  var collectionsEl = root.querySelector('[data-search-collections]');
  var productsEl = root.querySelector('[data-search-products]');
  var form = root.querySelector('[data-search-form]');
  var debounceTimer = null;

  function open() {
    root.classList.add('is-open');
    root.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(function() { input && input.focus(); }, 50);
  }
  function close() {
    root.classList.remove('is-open');
    root.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  if (trigger) trigger.addEventListener('click', function(e) {
    e.preventDefault();
    open();
  });

  root.addEventListener('click', function(e) {
    if (e.target.closest('[data-search-close]')) { e.preventDefault(); close(); }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && root.classList.contains('is-open')) close();
  });

  // Suggestions cliquables
  root.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-search-suggest]');
    if (!btn) return;
    var term = btn.getAttribute('data-search-suggest');
    if (input) {
      input.value = term;
      input.dispatchEvent(new Event('input', { bubbles: true }));
      input.focus();
    }
  });

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
    });
  }

  function renderResults(data) {
    var resources = (data && data.resources && data.resources.results) || {};
    var products = resources.products || [];
    var collections = resources.collections || [];
    var queries = resources.queries || [];

    // Collections : si vide, on affiche les "queries" (suggestions de termes) en fallback
    var colHtml = '';
    if (collections.length) {
      collections.slice(0, 6).forEach(function(c) {
        colHtml += '<li><a href="' + escapeHtml(c.url) + '">' + escapeHtml(c.title) + '</a></li>';
      });
    } else if (queries.length) {
      queries.slice(0, 6).forEach(function(q) {
        var url = '{{ routes.search_url }}?q=' + encodeURIComponent(q.text);
        colHtml += '<li><a href="' + escapeHtml(url) + '">' + escapeHtml(q.text) + '</a></li>';
      });
    } else {
      colHtml = '<li style="font-size:11px;color:rgba(15,15,15,0.45);">Aucun résultat</li>';
    }
    collectionsEl.innerHTML = colHtml;

    // Produits
    if (products.length === 0) {
      productsEl.innerHTML = '<div class="psq__empty">Aucun produit trouvé pour cette recherche.</div>';
    } else {
      var html = '';
      products.slice(0, 6).forEach(function(p) {
        var img = p.featured_image && p.featured_image.url
          ? '<img src="' + escapeHtml(p.featured_image.url) + '" alt="' + escapeHtml(p.title) + '" loading="lazy" decoding="async">'
          : '';
        var price = '';
        if (p.price) {
          var cents = parseFloat(p.price);
          if (!isNaN(cents)) {
            // p.price est déjà au format string (ex: "199.00")
            price = (Math.round(cents * 100) / 100).toFixed(2).replace('.', ',') + ' €';
          }
        }
        html += '<a href="' + escapeHtml(p.url) + '" class="psq__product-card">' +
                  '<div class="psq__product-card-img">' + img + '</div>' +
                  '<div class="psq__product-card-name">' + escapeHtml(p.title) + '</div>' +
                  '<div class="psq__product-card-price">' + price + '</div>' +
                '</a>';
      });
      productsEl.innerHTML = html;
    }
  }

  function fetchPredictive(q) {
    var url = '/search/suggest.json?q=' + encodeURIComponent(q) +
              '&resources[type]=product,collection,query' +
              '&resources[limit]=6' +
              '&resources[options][unavailable_products]=last';
    fetch(url, { headers: { 'Accept': 'application/json' }})
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (!data) return;
        // Vérifier que la requête est toujours d'actualité
        if (input.value.trim() === q) renderResults(data);
      })
      .catch(function() {});
  }

  if (input) {
    input.addEventListener('input', function() {
      var q = this.value.trim();
      if (q.length === 0) {
        emptyState.hidden = false;
        queryState.hidden = true;
        return;
      }
      emptyState.hidden = true;
      queryState.hidden = false;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() { fetchPredictive(q); }, 180);
    });
  }
})();
</script>

